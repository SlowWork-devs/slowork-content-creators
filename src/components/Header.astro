---
import { Image } from 'astro:assets';

import logoImg from '../assets/logo-slowork.png';
import { MAIN_SLOWORK_ORIGIN } from '../constants/site';
import LanguagePicker from './LanguagePicker.astro';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;

const homeHref = `${MAIN_SLOWORK_ORIGIN}/${lang}/`;

const logoAria =
  lang === 'es' ? 'Slowork — ir al sitio principal' : 'Slowork — go to main website';

/** Alt descriptivo para SEO e indexación de imagen; el enlace lleva aria-label de acción. */
const logoAlt = lang === 'es' ? 'Logotipo de Slowork' : 'Slowork logo';
---

<header
  role="banner"
  class="pointer-events-none fixed inset-x-0 top-0 z-30 w-full bg-(--color-bg-landing)/80 backdrop-blur-md py-6 px-6 md:px-12 border-b border-primary/5"
>
  <div
    class="pointer-events-auto mx-auto flex w-full max-w-7xl items-center justify-between gap-6"
  >
    <a
      href={homeHref}
      class="flex min-h-11 min-w-11 shrink-0 touch-manipulation items-center rounded-sm transition-opacity duration-200 hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/35 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100"
      aria-label={logoAria}
    >
      <Image
        src={logoImg}
        alt={logoAlt}
        width={200}
        class="h-9 w-auto max-w-[min(200px,42vw)] object-contain object-left md:h-10"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        densities={[1, 2]}
        sizes="(max-width: 768px) 42vw, 200px"
      />
    </a>
    <LanguagePicker lang={lang} />
  </div>
</header>
