---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { Play } from '@lucide/astro';

import defaultPoster from '../assets/creators-hero-poster.png';

interface Props {
  /** YouTube video ID (e.g. `dQw4w9WgXcQ`). */
  youtubeId: string;
  poster?: ImageMetadata;
  alt?: string;
  videoTitle?: string;
  playLabel?: string;
  moodLine?: string;
  posterPriority?: boolean;
}

const {
  youtubeId,
  poster = defaultPoster,
  alt = 'Vídeo Slowork, previsualización',
  videoTitle = 'Slowork',
  playLabel = 'Reproducir vídeo Slowork',
  moodLine,
  posterPriority = false,
} = Astro.props;

const facadeId = `vf-${crypto.randomUUID()}`;
---

<div class="video-facade-root w-full max-w-4xl">
  <div
    class="relative rounded-[1.125rem] p-[3px] shadow-[0_2px_8px_-2px_rgba(1,51,51,0.08),0_24px_56px_-20px_rgba(1,51,51,0.22),0_48px_80px_-36px_rgba(1,51,51,0.12)] sm:rounded-3xl sm:p-1"
    style="background: linear-gradient(145deg, color-mix(in srgb, white 55%, transparent) 0%, color-mix(in srgb, var(--color-base-200) 92%, var(--color-primary) 8%) 45%, color-mix(in srgb, var(--color-base-300) 88%, var(--color-primary) 12%) 100%);"
  >
    <div
      id={facadeId}
      class="video-facade relative aspect-video w-full overflow-hidden rounded-[1rem] bg-base-300 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.35),inset_0_0_0_1px_rgba(1,51,51,0.06),0_1px_2px_rgba(1,51,51,0.05)] sm:rounded-2xl"
    >
      <div class="video-facade__embed absolute inset-0 z-0" hidden></div>
      <button
        type="button"
        class="video-facade__trigger group absolute inset-0 z-10 flex cursor-pointer items-center justify-center border-0 bg-transparent p-0 outline-none transition-[transform,box-shadow] duration-300 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-base-100"
        aria-label={playLabel}
      >
        <Image
          src={poster}
          alt={alt}
          class="pointer-events-none h-full w-full object-contain scale-[1.02] motion-safe:transition-transform motion-safe:duration-[2.8s] motion-safe:ease-out group-hover:scale-100"
          widths={[640, 960, 1280]}
          sizes="(max-width: 768px) 100vw, 896px"
          loading={posterPriority ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={posterPriority ? 'high' : 'low'}
        />
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-br from-primary/30 via-transparent to-secondary/[0.12]"
          aria-hidden="true"
        />
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-t from-base-100/45 via-transparent to-primary/[0.08]"
          aria-hidden="true"
        />
        <div
          class="pointer-events-none absolute inset-0 opacity-[0.07] mix-blend-overlay"
          style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');"
          aria-hidden="true"
        />
        <span
          class="pointer-events-none absolute flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-content shadow-[0_4px_14px_rgba(1,51,51,0.25),0_12px_32px_-4px_rgba(1,51,51,0.35)] ring-2 ring-base-100/45 backdrop-blur-[2px] transition-[transform,box-shadow] duration-300 ease-out group-hover:scale-[1.07] group-hover:shadow-[0_6px_20px_rgba(1,51,51,0.28),0_16px_40px_-6px_rgba(1,51,51,0.38)] group-focus-visible:scale-[1.07] md:h-[4.25rem] md:w-[4.25rem]"
          aria-hidden="true"
        >
          <Play
            class="ml-0.5 h-7 w-7 fill-current stroke-none md:h-8 md:w-8"
            fill="currentColor"
            stroke="none"
            stroke-width={0}
            size={28}
            aria-hidden="true"
          />
        </span>
      </button>
    </div>
  </div>
  {
    moodLine?.trim() ? (
      <p class="mt-5 w-full text-center text-sm font-normal leading-snug tracking-wide text-primary/75 text-balance md:text-[0.9375rem]">
        {moodLine.trim()}
      </p>
    ) : null
  }
</div>

<script define:vars={{ facadeId, youtubeId, videoTitle }}>
  (() => {
    const root = document.getElementById(facadeId);
    if (!root) return;
    const trigger = root.querySelector('.video-facade__trigger');
    const host = root.querySelector('.video-facade__embed');
    if (!trigger || !host) return;

    trigger.addEventListener('click', () => {
      if (host.dataset.loaded === '1') return;
      host.dataset.loaded = '1';
      trigger.hidden = true;
      host.hidden = false;

      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${youtubeId}?autoplay=1&rel=0&modestbranding=1`;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.setAttribute('title', videoTitle);
      iframe.className =
        'absolute inset-0 box-border h-full w-full max-h-full max-w-full border-0';
      host.appendChild(iframe);
    });
  })();
</script>
