---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

import defaultPoster from '../assets/slowork-manifesto-video-poster.png';

interface Props {
  /** ID de YouTube (solo el valor de `v=` en youtube.com/watch?v=…), vídeo «Manifiesto Slowork». */
  youtubeId: string;
  /** Sustituye el poster por uno de alta resolución cuando lo tengas en `src/assets`. */
  poster?: ImageMetadata;
  alt?: string;
  iframeTitle?: string;
  playLabel?: string;
  /** Línea de intención visual (v2): calm, intentional, real — debajo del facade. */
  moodLine?: string;
  /** LCP / above-the-fold: poster con eager + fetchpriority high (p. ej. creators sin imagen hero). */
  posterPriority?: boolean;
}

const {
  youtubeId,
  poster = defaultPoster,
  alt = 'Vídeo: Manifiesto Slowork — previsualización',
  iframeTitle = 'Manifiesto Slowork',
  playLabel = 'Reproducir vídeo: Manifiesto Slowork',
  moodLine,
  posterPriority = false,
} = Astro.props;

const facadeId = `vf-${crypto.randomUUID()}`;
const embedSrc = `https://www.youtube-nocookie.com/embed/${youtubeId}?autoplay=1&rel=0`;
---

<div class="video-facade-root w-full max-w-4xl">
  <div
    id={facadeId}
    class="video-facade relative aspect-video w-full overflow-hidden rounded-2xl bg-base-300 shadow-[0_14px_44px_-14px_rgba(1,51,51,0.24),0_4px_14px_-4px_rgba(1,51,51,0.10)] ring-1 ring-primary/22"
  >
    <div class="video-facade__embed absolute inset-0 z-0" hidden></div>
    <button
      type="button"
      class="video-facade__trigger group absolute inset-0 z-10 flex cursor-pointer items-center justify-center border-0 bg-transparent p-0 text-left outline-none ring-primary transition-shadow duration-300 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100"
      aria-label={playLabel}
    >
      <Image
        src={poster}
        alt={alt}
        class="pointer-events-none h-full w-full object-cover scale-[1.02] motion-safe:transition-transform motion-safe:duration-[2.8s] motion-safe:ease-out group-hover:scale-100"
        widths={[640, 960, 1280]}
        sizes="(max-width: 768px) 100vw, 896px"
        loading={posterPriority ? 'eager' : 'lazy'}
        decoding="async"
        fetchpriority={posterPriority ? 'high' : 'low'}
      />
      <!-- Naturaleza + calidez / comunidad: capas muy suaves sobre el poster -->
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-br from-primary/30 via-transparent to-secondary/[0.12]"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-base-100/45 via-transparent to-primary/[0.08]"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.07] mix-blend-overlay"
        style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');"
        aria-hidden="true"
      >
      </div>
      <!-- Play: intencional, menos «alarma» que el amarillo puro -->
      <span
        class="pointer-events-none absolute flex h-14 w-14 items-center justify-center rounded-full bg-primary/88 text-primary-content shadow-[0_8px_30px_rgba(30,51,24,0.35)] backdrop-blur-[2px] transition-transform duration-300 ease-out group-hover:scale-[1.06] group-focus-visible:scale-[1.06] md:h-16 md:w-16"
        aria-hidden="true"
      >
        <svg class="ml-0.5 h-7 w-7 md:h-8 md:w-8" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M8 5v14l11-7L8 5z"></path>
        </svg>
      </span>
    </button>
  </div>
  {
    moodLine?.trim() ? (
      <p class="mt-4 text-center text-sm font-medium leading-snug tracking-wide text-base-content/55 text-balance md:text-[0.9375rem]">
        {moodLine.trim()}
      </p>
    ) : null
  }
</div>

<script define:vars={{ facadeId, embedSrc, iframeTitle }}>
  (() => {
    const root = document.getElementById(facadeId);
    if (!root) return;
    const trigger = root.querySelector('.video-facade__trigger');
    const host = root.querySelector('.video-facade__embed');
    if (!trigger || !host) return;

    trigger.addEventListener('click', () => {
      if (host.dataset.loaded === '1') return;
      host.dataset.loaded = '1';
      trigger.hidden = true;
      host.hidden = false;

      const iframe = document.createElement('iframe');
      iframe.src = embedSrc;
      iframe.title = iframeTitle;
      iframe.loading = 'lazy';
      iframe.allow =
        'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      iframe.className = 'absolute inset-0 h-full w-full border-0';
      host.appendChild(iframe);
    });
  })();
</script>
