---
import { Icon } from 'astro-icon/components';

import type { CreatorFaqItem } from '../models/creator-landing-content.model';

interface Props {
  heading: string;
  items: CreatorFaqItem[];
}

const { heading, items } = Astro.props;
const headingId = 'creators-faq-heading';
---

<div class="w-full" aria-labelledby={heading.trim() ? headingId : undefined}>
  {
    heading.trim() ? (
      <h2
        id={headingId}
        class="mx-auto mb-10 max-w-3xl text-center text-2xl font-bold tracking-[-0.02em] text-primary text-balance md:text-4xl"
      >
        {heading.trim()}
      </h2>
    ) : null
  }
  <div
    class="mx-auto w-full max-w-2xl overflow-hidden rounded-3xl border border-primary/10 bg-base-100/90 shadow-[0_2px_24px_-12px_rgba(1,51,51,0.12)]"
  >
    {
      items.map((item) => (
        <details class="group border-b border-primary/8 last:border-b-0">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-left transition-colors hover:bg-primary/[0.03] [&::-webkit-details-marker]:hidden">
            <span class="text-base font-semibold text-primary text-balance">{item.question}</span>
            <span
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-primary/10 text-primary/60 transition-transform duration-300 group-open:rotate-180"
              aria-hidden="true"
            >
              <Icon name="lucide:chevron-down" class="h-[18px] w-[18px] shrink-0 stroke-2 text-current" aria-hidden="true" />
            </span>
          </summary>
          <div class="border-t border-primary/6 bg-base-100/50 px-6 pb-6 pt-2">
            <p class="m-0 text-left text-sm leading-relaxed text-primary/80 text-pretty">{item.answer}</p>
          </div>
        </details>
      ))
    }
  </div>
</div>
