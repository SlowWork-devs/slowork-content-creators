---
import type { CreatorCreditRates } from '../models/creator-credits.model';

type CreditKey = keyof CreatorCreditRates;

interface Row {
  key: CreditKey;
  label: string;
}

interface Props {
  rates: CreatorCreditRates;
  rows: Row[];
  /** Etiqueta junto al número (p. ej. "Credits" / "Créditos"). */
  creditsUnitLabel: string;
  formatColumnLabel: string;
  valueColumnLabel: string;
  caption: string;
  footnote: string;
}

const { rates, rows, creditsUnitLabel, formatColumnLabel, valueColumnLabel, caption, footnote } = Astro.props;

const rowsWithCredits = rows.map((row) => ({
  ...row,
  credits: rates[row.key],
}));
---

<div class="credit-table mx-auto w-full min-w-0 max-w-2xl text-center">
  <div class="overflow-x-auto rounded-2xl [-webkit-overflow-scrolling:touch] text-left">
    <table class="w-full min-w-[min(100%,20rem)] table-fixed border-collapse">
      <caption class="sr-only">
        {caption}
      </caption>
      <thead>
        <tr class="border-b border-primary/15">
          <th
            scope="col"
            class="w-[58%] pb-4 pt-1 text-start align-bottom text-[0.65rem] font-bold uppercase tracking-[0.16em] text-primary/55 md:w-[62%]"
          >
            {formatColumnLabel}
          </th>
          <th
            scope="col"
            class="w-[42%] pb-4 pt-1 text-end align-bottom text-[0.65rem] font-bold uppercase tracking-[0.16em] text-primary/55 md:w-[38%]"
          >
            {valueColumnLabel}
          </th>
        </tr>
      </thead>
      <tbody>
        {
          rowsWithCredits.map((row) => (
            <tr class="border-b border-primary/8 transition-colors last:border-0 hover:bg-primary/[0.02]">
              <td class="py-4 pe-4 align-middle text-base font-medium leading-snug text-primary/88 md:py-5 md:pe-6 md:text-lg text-pretty">
                {row.label}
              </td>
              <td class="py-4 align-middle text-end md:py-5">
                <div class="inline-flex flex-col items-end gap-0.5 sm:inline-flex">
                  <span class="font-editorial-serif text-3xl italic leading-none text-primary tabular-nums md:text-4xl">
                    {row.credits}
                  </span>
                  <span class="text-end text-[0.65rem] font-bold uppercase tracking-[0.18em] text-primary/50">
                    {creditsUnitLabel}{' '}
                    <span class="font-medium normal-case tracking-normal text-primary/75">(${row.credits})</span>
                  </span>
                </div>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
  <p class="mx-auto mt-8 max-w-lg text-center text-sm leading-relaxed text-primary/65">
    {footnote}
  </p>
</div>
