---
import type { CreatorCreditRates } from '../models/creator-credits.model';

type CreditKey = keyof CreatorCreditRates;

interface Row {
  key: CreditKey;
  label: string;
}

interface Props {
  rates: CreatorCreditRates;
  rows: Row[];
  /** Etiqueta junto al número (p. ej. "Credits" / "Créditos"). */
  creditsUnitLabel: string;
  footnote: string;
}

const { rates, rows, creditsUnitLabel, footnote } = Astro.props;

const rowsWithCredits = rows.map((row) => ({
  ...row,
  credits: rates[row.key],
}));
---

<div class="credit-table mt-8 w-full min-w-0 max-w-2xl">
  <ul
    class="divide-y divide-primary/10 rounded-xl border border-primary/10 bg-base-200/50 px-2 shadow-[0_2px_16px_-8px_rgba(1,51,51,0.05)] ring-1 ring-primary/10 sm:px-1 sm:shadow-[0_4px_22px_-10px_rgba(1,51,51,0.14),0_1px_3px_rgba(1,51,51,0.06)] sm:ring-primary/10"
    role="list"
  >
    {
      rowsWithCredits.map((row) => (
        <li class="flex flex-col gap-2 px-5 py-4 first:pt-5 last:pb-5 sm:flex-row sm:flex-wrap sm:items-baseline sm:justify-between sm:gap-x-4 sm:gap-y-1 sm:px-5 md:py-[1.125rem]">
          <span class="min-w-0 text-[0.9375rem] leading-snug text-primary sm:max-w-[min(100%,20rem)] md:text-base">
            {row.label}
          </span>
          <span class="flex min-w-0 flex-wrap items-baseline gap-x-2 gap-y-0.5 tabular-nums sm:shrink-0 sm:justify-end">
            <span class="text-lg font-semibold text-primary md:text-xl">{row.credits}</span>
            <span class="text-sm font-medium text-primary/90 md:text-base">{creditsUnitLabel}</span>
            <span class="text-sm text-primary/90 md:text-base">(${row.credits})</span>
          </span>
        </li>
      ))
    }
  </ul>
  <p class="mt-6 max-w-xl text-xs leading-relaxed text-primary md:text-[0.8125rem]">
    {footnote}
  </p>
</div>
