---
import { MAIN_SLOWORK_ORIGIN } from '../constants/site';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const currentYear = new Date().getFullYear();

const translations = {
  es: {
    rights: 'Todos los derechos reservados.',
    privacy: 'Política de Privacidad',
    contact: 'Contacto',
    cookies: 'Política de Cookies',
    legal: 'Aviso Legal',
    terms: 'Términos y Condiciones',
    navAria: 'Enlaces legales y de contacto',
  },
  en: {
    rights: 'All rights reserved.',
    privacy: 'Privacy Policy',
    contact: 'Contact',
    cookies: 'Cookies Policy',
    legal: 'Legal Notice',
    terms: 'Terms & Conditions',
    navAria: 'Legal and contact links',
  },
} as const;

const t = translations[lang];

const langPath = (path: string) => `${MAIN_SLOWORK_ORIGIN}/${lang}${path}`;
const contactHref = `${MAIN_SLOWORK_ORIGIN}/${lang}/#contact`;

const linkClass =
  'inline-flex min-h-10 min-w-0 max-w-full items-center justify-center rounded-sm px-1.5 py-2 touch-manipulation text-balance transition-colors hover:text-secondary focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-primary sm:min-h-11 sm:px-2';
const sepClass = 'hidden select-none text-white/45 sm:inline sm:shrink-0';
const sepDotClass = 'inline text-white/45 sm:hidden';
---

<footer
  class="mt-auto w-full min-w-0 bg-primary py-6 pb-[max(1.5rem,env(safe-area-inset-bottom))] font-sans text-white/90 sm:py-8"
>
  <div class="mx-auto w-full min-w-0 max-w-7xl px-4 sm:px-6 lg:px-8">
    <nav
      class="mx-auto flex w-full min-w-0 max-w-full flex-wrap items-center justify-center gap-x-1.5 gap-y-2 text-center text-[clamp(0.6875rem,0.35rem+2vw,1rem)] leading-snug sm:gap-x-2 sm:gap-y-2.5 sm:text-sm md:text-base"
      aria-label={t.navAria}
    >
      <span class="w-full max-w-prose text-balance sm:w-auto sm:max-w-none sm:whitespace-nowrap">
        © {currentYear} Slowork. {t.rights}
      </span>

      <span class="basis-full sm:hidden" aria-hidden="true"></span>

      <a href={langPath('/privacy-policy/')} class={linkClass}>{t.privacy}</a>
      <span class={sepClass} aria-hidden="true">|</span>
      <span class={sepDotClass} aria-hidden="true">·</span>

      <a href={contactHref} class={linkClass}>{t.contact}</a>
      <span class={sepClass} aria-hidden="true">|</span>
      <span class={sepDotClass} aria-hidden="true">·</span>

      <a href={langPath('/cookies-policy/')} class={linkClass}>{t.cookies}</a>
      <span class={sepClass} aria-hidden="true">|</span>
      <span class={sepDotClass} aria-hidden="true">·</span>

      <a href={langPath('/legal-notice/')} class={linkClass}>{t.legal}</a>
      <span class={sepClass} aria-hidden="true">|</span>
      <span class={sepDotClass} aria-hidden="true">·</span>

      <a href={langPath('/terms-and-conditions/')} class={linkClass}>{t.terms}</a>
    </nav>
  </div>
</footer>
