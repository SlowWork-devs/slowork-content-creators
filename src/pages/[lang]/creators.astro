---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';

import CreatorsLegalFooter from '../../components/CreatorsLegalFooter.astro';
import VideoFacade from '../../components/VideoFacade.astro';
import { MAIN_SLOWORK_ORIGIN, manifestoYoutubeId } from '../../constants/site';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const items = await getCollection('creators');
  return items.map((entry) => ({
    params: { lang: entry.data.locale },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'creators'>;
}

const { entry } = Astro.props;
const lang = Astro.params.lang as 'en' | 'es';

const { title, heroMicrocopy, subheadline, seoDescription, benefitBlocks, whyProgram } = entry.data;
const heroMicrocopyTrimmed = heroMicrocopy?.trim() ?? '';

const subheadlineParagraphs = subheadline
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter(Boolean);

const { Content } = await render(entry);

const ui = {
  en: {
    cta: 'Apply to join the creators program',
    benefitsHeading: 'Why become a Slowork creator',
    pageTitle: `${title} | Slowork`,
    videoAlt: 'Manifiesto Slowork — video preview',
    playLabel: 'Play video: Slowork Manifesto',
    iframeTitle: 'Slowork Manifesto',
  },
  es: {
    cta: 'Solicitar unirme al programa de creadores',
    benefitsHeading: 'Por qué unirte como creador Slowork',
    pageTitle: `${title} | Slowork`,
    videoAlt: 'Manifiesto Slowork — vista previa del vídeo',
    playLabel: 'Reproducir vídeo: Manifiesto Slowork',
    iframeTitle: 'Manifiesto Slowork',
  },
} as const;

const t = ui[lang];

const path = `/${lang}/creators/`;
const baseForUrl = Astro.site ?? Astro.url.origin;
const canonicalURL = new URL(path, baseForUrl).href;
const esCreatorsURL = new URL('/es/creators/', baseForUrl).href;
const enCreatorsURL = new URL('/en/creators/', baseForUrl).href;

const alternates = [
  { hreflang: 'es', href: esCreatorsURL },
  { hreflang: 'en', href: enCreatorsURL },
  { hreflang: 'x-default', href: esCreatorsURL },
] as const;

const ctaHref = `${MAIN_SLOWORK_ORIGIN}/${lang}/#contact`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: seoDescription,
  url: canonicalURL,
  provider: {
    '@type': 'Organization',
    name: 'Slowork',
    url: MAIN_SLOWORK_ORIGIN,
  },
  areaServed: {
    '@type': 'Place',
    name: 'Worldwide',
  },
  availableLanguage: ['en', 'es'],
  serviceType: 'Content creator program',
};
---

<BaseLayout title={t.pageTitle} lang={lang}>
  <Fragment slot="head">
    <meta name="description" content={seoDescription} />
    <link rel="canonical" href={canonicalURL} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <div class="flex min-h-dvh flex-col bg-base-100 text-base-content">
    <main
      class="mx-auto flex w-full max-w-4xl flex-1 flex-col items-center gap-10 px-6 py-12 md:gap-12 md:py-16"
    >
      <header class="flex w-full flex-col items-center gap-6 text-center">
        <h1 class="max-w-3xl font-bold text-primary text-balance">
          {title}
        </h1>
        <div class="max-w-2xl space-y-4 text-lg text-base-content/85 text-balance md:text-xl">
          {subheadlineParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
        <a
          href={ctaHref}
          class="btn btn-secondary min-h-12 px-8 text-base font-semibold shadow-md transition-transform duration-200 hover:scale-105 focus-visible:scale-105 active:scale-95"
        >
          {t.cta}
        </a>
        {heroMicrocopyTrimmed ? (
          <p class="max-w-xl text-sm text-base-content/65 text-balance">{heroMicrocopyTrimmed}</p>
        ) : null}
      </header>

      <section class="w-full" aria-label={t.iframeTitle}>
        <VideoFacade
          youtubeId={manifestoYoutubeId}
          alt={t.videoAlt}
          iframeTitle={t.iframeTitle}
          playLabel={t.playLabel}
        />
      </section>

      <section
        class="w-full border-t border-primary/10 pt-10 md:pt-12"
        aria-labelledby="benefits-heading"
      >
        <h2 id="benefits-heading" class="mb-8 text-center text-xl font-bold text-primary md:text-2xl">
          {t.benefitsHeading}
        </h2>
        <ul class="grid gap-6 sm:grid-cols-2">
          {benefitBlocks.map((block) => (
            <li class="rounded-box border border-primary/15 bg-base-100 p-5 shadow-sm">
              <h3 class="font-semibold text-primary">{block.title}</h3>
              <p class="mt-2 text-sm text-base-content/85 leading-relaxed">{block.text}</p>
            </li>
          ))}
        </ul>
      </section>

      <section
        class="w-full border-t border-primary/10 pt-10 md:pt-12"
        aria-labelledby="why-program-heading"
      >
        <h2 id="why-program-heading" class="text-xl font-bold text-primary md:text-2xl">
          {whyProgram.heading}
        </h2>
        <p class="mt-4 max-w-3xl text-base text-base-content/85 leading-relaxed">
          {whyProgram.intro}
        </p>
        <ul class="mt-4 list-inside list-disc space-y-2 text-base text-base-content/85">
          {whyProgram.aims.map((aim) => (
            <li>{aim}</li>
          ))}
        </ul>
        <p class="mt-6 max-w-3xl font-medium text-primary leading-relaxed">
          {whyProgram.closing}
        </p>
      </section>

      <article
        class="w-full max-w-none border-t border-primary/10 pt-10 md:pt-12 [&_h2]:mt-10 [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-primary [&_h2]:first:mt-0 [&_p]:mb-4 [&_p]:leading-relaxed [&_p]:text-base-content/90 [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:text-base-content/90 [&_strong]:font-semibold [&_strong]:text-base-content"
      >
        <Content />
      </article>
    </main>

    <CreatorsLegalFooter lang={lang} />
  </div>
</BaseLayout>
