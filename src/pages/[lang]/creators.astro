---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import {
  ArrowDown,
  ArrowRight,
  Award,
  Camera,
  Check,
  CircleCheck,
  CircleDollarSign,
  CircleX,
  ClipboardCheck,
  CloudDownload,
  Paintbrush,
  Sparkles,
  Table2,
  TrendingUp,
  X,
} from '@lucide/astro';

import CreditTable from '../../components/CreditTable.astro';
import ExploreAppMockupScreen from '../../components/ExploreAppMockupScreen.astro';
import CreatorsFaqSection from '../../components/CreatorsFaqSection.astro';
import CreatorsLegalFooter from '../../components/CreatorsLegalFooter.astro';
import CreatorsSignatureButton from '../../components/CreatorsSignatureButton.astro';
import EditorialHeading from '../../components/EditorialHeading.astro';
import Header from '../../components/Header.astro';
import SectionEyebrow from '../../components/SectionEyebrow.astro';
import VideoFacade from '../../components/VideoFacade.astro';
import { parseEditorialHeading } from '../../utils/editorial-heading';
import type { CreatorCreditRates } from '../../models/creator-credits.model';
import { creatorsHeroVideoSrc, creatorsHeroVideoWebmSrc, MAIN_SLOWORK_ORIGIN } from '../../constants/site';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const items = await getCollection('creators');
  return items.map((entry) => ({
    params: { lang: entry.data.locale },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'creators'>;
}

const { entry } = Astro.props;
const lang = Astro.params.lang as 'en' | 'es';

const { title, heroMicrocopy, subheadline, seoDescription, benefitBlocks, faqItems, creditRates } = entry.data;

type CreditRow = { key: keyof CreatorCreditRates; label: string };
const heroMicrocopyTrimmed = heroMicrocopy?.trim() ?? '';

const subheadlineParagraphs = subheadline
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter(Boolean);

const ui = {
  en: {
    cta: 'Apply now',
    ctaAria:
      'Apply to join the Slowork creators program — opens the contact section on slowork.app in this window',
    heroBadge: 'Slowork creators',
    pageTitle: 'Slowork Creators | A different way of living and working',
    videoAlt:
      'Slowork program video — remote work app, nature workspace and intentional lifestyle storytelling',
    playLabel: 'Play the Slowork video — starts playback when you tap',
    videoTitle: 'Slowork program video',
    videoMoodLine: 'Watch now to see how it works',
    faqHeading: 'Frequently asked questions',
    creditsHeading: 'How credits work',
    creditsUnitLabel: 'Credits',
    creditsTableFormatCol: 'Content type',
    creditsTableValueCol: 'Reward',
    creditsTableCaption: 'Credits by content type',
    creditsFootnote: '1 Credit = 1 USD. Not redeemable for cash.',
    creditRows: [
      { key: 'story', label: 'Instagram Story' },
      { key: 'carousel', label: 'Carousel (Instagram or similar)' },
      { key: 'reel', label: 'Reel / short vertical video (Instagram, TikTok)' },
      { key: 'longFormVideo', label: 'Long-form video (typically 40+ min)' },
      { key: 'blogPost', label: 'Blog article' },
    ] satisfies CreditRow[],
    onboardingHeading: 'What happens after you apply',
    onboardingSteps: [
      {
        num: '01',
        title: 'Apply',
        description: 'Send your application—we read every profile with care, not as a volume funnel.',
      },
      {
        num: '02',
        title: 'Review',
        description: 'We assess alignment, storytelling and quality against the Slowork creator brief.',
      },
      {
        num: '03',
        title: 'Onboarding',
        description: 'Selected creators get early access, content guidelines and onboarding into the credit system.',
      },
    ],
    // New UI text for the 13 points
    storyHeading: 'Remote work was supposed to feel *freer* than this',
    storyBody: [
      'Somewhere along the way, remote work became the same old lifestyle. Same stress. Same burnout. Just with a laptop.',
      'Slowork was built as a response to that.',
      'We believe remote work should feel more human — more connected to place, to people, and to the way you actually want to live.',
    ],
    whatIsHeading: 'What is Slowork?',
    whatIsBody: [
      'Slowork is not just another booking app.',
      "It's a platform for remote workers who want more than good WiFi — places that support deep work, natural environments that improve how you feel, experiences that help you disconnect, and a real sense of community while you travel.",
      'In practical terms: discover remote-ready stays, organise your trip, explore local experiences and connect with others through the app.',
      'A platform, yes. But more importantly — a lifestyle proposition.',
    ],
    notTypicalHeading: 'This is not a typical creator program',
    comparisonWrongLabel: 'The wrong fit',
    comparisonRightLabel: 'The perfect fit',
    notTypicalBody: [
      'Most programs are built around campaigns, deliverables and transactional promotion. This one is different.',
      "We're not looking for creators who post the most. We're looking for creators who can represent something meaningful.",
      "If your content is driven by fast ads and generic travel aesthetics — this probably won't fit.",
      "If your content feels thoughtful, visual and intentional — you're exactly who this was designed for.",
    ],
    whyBecomeHeading: 'Why become a Slowork creator',
    whyBecomeIntro:
      "Not every collaboration helps you create work you're proud of. Slowork creators don't just promote a product — they document a lifestyle people already aspire to.",
    whoForHeading: 'Who this program is for',
    whoForNiches: ['travel', 'lifestyle', 'digital nomad', 'remote work', 'intentional living', 'wellbeing'],
    whoForBody: [
      'Follower count is not the main filter.',
      'What matters: content that feels relevant, visually strong and genuinely aligned with the Slowork world.',
      "We're especially looking for creators who create in English or subtitle in English, already document meaningful environments, tell stories — not just post aesthetics — and are native to Instagram, TikTok or YouTube.",
    ],
    greatContentHeading: 'What great Slowork content looks like',
    greatContentIntro:
      "We're not looking for content that sells hard. We're looking for content that makes people feel something.",
    contentWeWant: {
      title: 'Content we want',
      items: [
        'Aspirational POVs',
        'Remote work in nature',
        'City vs nature contrasts',
        'Slow routines',
        'Meaningful storytelling',
        'Reflections on work, life and environment',
      ],
    },
    contentNotApproved: {
      title: "Content that won't be approved",
      items: [
        'Direct app promotion',
        'Generic travel montages',
        'Spammy or low-effort content',
        'Giveaway formats',
        'Money-first messaging',
      ],
    },
    howItWorksHeading: 'How it *works*',
    howItWorksIntro: 'The system is intentionally simple.',
    howItWorksSteps: [
      'Create content',
      'Mention Slowork clearly',
      'Submit it for review',
      'We review it manually',
      'Earn credits',
    ],
    creditsIntro: [
      "Slowork creators don't earn cash per post. They earn credits that unlock the experience.",
      'Each credit = $1 USD in value — redeemable for stays and experiences inside the platform. Credits are not withdrawable.',
      "Credits feel like access, not payment. They bring you closer to the lifestyle you're representing.",
    ],
    whyBuiltHeading: 'Why we built this program',
    whyBuiltIntro:
      'Slowork is in its early stage. Right now, the goal is not scale. It is clarity, visibility and identity.',
    whyBuiltAims: [
      'Build organic awareness',
      'Shape how the brand is perceived',
      'Understand what stories resonate',
      'Attract the right creators early',
      'Lay the foundation for community',
    ],
    whyBuiltClosing: 'This is storytelling before *growth*.',
    whatNextHeading: 'What happens after you apply',
    whatNextBody: [
      "If your profile feels aligned, we'll review your application.",
      'Selected creators may receive early access, content guidelines, onboarding into the credit system and future collaboration opportunities.',
      "You don't need to be a full-time digital nomad. You just need to create content that genuinely fits this world.",
    ],
    finalCtaHeading: 'If your content already reflects this way of life — you may be a *fit*.',
    finalCtaParagraphs: [
      "Slowork is being built right now. The creators who join early won't just promote it. They'll help define what it becomes.",
      'Create content that feels aligned. Earn your way into the experience. Help represent a better version of remote work.',
    ],
  },
  es: {
    cta: 'Solicitar acceso',
    ctaAria:
      'Solicitar unirme al programa de creadores de Slowork — abre la sección de contacto en slowork.app en esta ventana',
    heroBadge: 'Creadores Slowork',
    pageTitle: 'Slowork Creators | Una forma distinta de vivir y trabajar',
    videoAlt:
      'Vídeo del programa Slowork — app de trabajo remoto, espacios en naturaleza y estilo de vida intencional',
    playLabel: 'Reproducir el vídeo de Slowork — inicia la reproducción al pulsar',
    videoTitle: 'Vídeo del programa Slowork',
    videoMoodLine: 'Echa un vistazo para ver cómo funciona',
    faqHeading: 'Preguntas frecuentes',
    creditsHeading: 'Cómo funcionan los créditos',
    creditsUnitLabel: 'Créditos',
    creditsTableFormatCol: 'Tipo de contenido',
    creditsTableValueCol: 'Recompensa',
    creditsTableCaption: 'Créditos por tipo de contenido',
    creditsFootnote: '1 crédito = 1 USD. No canjeable en efectivo.',
    creditRows: [
      { key: 'story', label: 'Historia de Instagram' },
      { key: 'carousel', label: 'Carrusel (Instagram o similar)' },
      { key: 'reel', label: 'Reel / vídeo corto vertical (Instagram, TikTok)' },
      { key: 'longFormVideo', label: 'Vídeo largo (típicamente +40 min)' },
      { key: 'blogPost', label: 'Artículo de blog' },
    ] satisfies CreditRow[],
    onboardingHeading: 'Qué pasa después de aplicar',
    onboardingSteps: [
      {
        num: '01',
        title: 'Solicitar',
        description: 'Envías tu solicitud; leemos cada perfil con calma, sin tratarlo como un embudo masivo.',
      },
      {
        num: '02',
        title: 'Revisión',
        description: 'Valoramos alineación, narrativa y calidad frente al brief de creadores Slowork.',
      },
      {
        num: '03',
        title: 'Onboarding',
        description: 'Si encajas, acceso anticipado, guías de contenido y entrada al sistema de créditos.',
      },
    ],
    // New UI text for the 13 points (Spanish translations)
    storyHeading: 'El trabajo remoto debía sentirse más *libre* que esto',
    storyBody: [
      'En algún momento, el trabajo remoto se convirtió en el mismo estilo de vida de siempre. Mismo estrés. Mismo agotamiento. Solo que con un portátil.',
      'Slowork nació como respuesta a eso.',
      'Creemos que el trabajo remoto debería sentirse más humano — más ligado al lugar, a las personas y a la forma en que realmente quieres vivir.',
    ],
    whatIsHeading: '¿Qué es Slowork?',
    whatIsBody: [
      'Slowork no es solo otra app de reservas.',
      'Es una plataforma para personas en remoto que quieren algo más que buen WiFi: espacios que favorezcan el trabajo profundo, entornos naturales que mejoren cómo te sientes, experiencias que te ayuden a desconectar y un sentido real de comunidad mientras viajas.',
      'En la práctica: descubre estancias listas para el remoto, organiza tu viaje, explora experiencias locales y conéctate con otras personas desde la app.',
      'Una plataforma, sí. Pero, sobre todo, una propuesta de estilo de vida.',
    ],
    notTypicalHeading: 'Este no es un programa típico para creadores',
    comparisonWrongLabel: 'No encaja',
    comparisonRightLabel: 'Encaja de verdad',
    notTypicalBody: [
      'La mayoría de programas giran en torno a campañas, entregables y promoción transaccional. Este es distinto.',
      'No buscamos a quien más publica. Buscamos a quienes pueden representar algo con significado.',
      'Si tu contenido se mueve por anuncios rápidos y estéticas de viaje genéricas, probablemente no encaje.',
      'Si tu contenido se siente reflexivo, visual e intencionado, eres justo a quien va dirigido.',
    ],
    whyBecomeHeading: 'Por qué unirte como creador Slowork',
    whyBecomeIntro:
      'No toda colaboración te ayuda a crear un trabajo del que te sientas orgulloso. Los creadores Slowork no solo promocionan un producto: documentan un estilo de vida al que mucha gente ya aspira.',
    whoForHeading: 'Para quién es este programa',
    whoForNiches: ['viajes', 'estilo de vida', 'nómada digital', 'trabajo remoto', 'vida intencionada', 'bienestar'],
    whoForBody: [
      'El número de seguidores no es el filtro principal.',
      'Lo que importa: un contenido relevante, con fuerza visual y alineado de verdad con el universo Slowork.',
      'Nos interesan especialmente perfiles que crean en inglés o subtitulan en inglés, ya documentan entornos con significado, cuentan historias y no solo enseñan estética, y publican de forma nativa en Instagram, TikTok o YouTube.',
    ],
    greatContentHeading: 'Cómo es el contenido Slowork que buscamos',
    greatContentIntro:
      'No buscamos contenido que venda a empujones. Buscamos contenido que haga sentir algo.',
    contentWeWant: {
      title: 'Contenido que queremos',
      items: [
        'Puntos de vista aspiracionales',
        'Trabajo remoto en la naturaleza',
        'Contrastes ciudad vs naturaleza',
        'Rutinas pausadas',
        'Narrativa con sentido',
        'Reflexiones sobre trabajo, vida y entorno',
      ],
    },
    contentNotApproved: {
      title: 'Contenido que no aprobaremos',
      items: [
        'Promoción directa de la app',
        'Montajes de viaje genéricos',
        'Contenido spam o de bajo esfuerzo',
        'Formatos tipo sorteo',
        'Mensajes centrados solo en dinero',
      ],
    },
    howItWorksHeading: 'Cómo *funciona*',
    howItWorksIntro: 'El sistema es deliberadamente sencillo.',
    howItWorksSteps: [
      'Crea contenido',
      'Menciona Slowork con claridad',
      'Envíalo a revisión',
      'Lo revisamos manualmente',
      'Ganas créditos',
    ],
    creditsIntro: [
      'Los creadores Slowork no cobran en efectivo por publicación. Ganan créditos que desbloquean la experiencia.',
      'Cada crédito equivale a 1 USD en valor, canjeable por estancias y experiencias dentro de la plataforma. Los créditos no son retirables.',
      'Los créditos se sienten como acceso, no como pago. Te acercan al estilo de vida que representas.',
    ],
    whyBuiltHeading: 'Por qué hemos creado este programa',
    whyBuiltIntro:
      'Slowork está en una etapa temprana. Ahora mismo, el objetivo no es escalar. Es claridad, visibilidad e identidad.',
    whyBuiltAims: [
      'Generar conciencia orgánica',
      'Definir cómo se percibe la marca',
      'Entender qué historias resuenan',
      'Atraer a los creadores adecuados desde el principio',
      'Sentar las bases de la comunidad',
    ],
    whyBuiltClosing: 'Esto es storytelling antes que *crecimiento*.',
    whatNextHeading: 'Qué pasa después de aplicar',
    whatNextBody: [
      'Si tu perfil encaja, revisamos tu solicitud.',
      'Quienes resulten seleccionados pueden recibir acceso anticipado, guías de contenido, onboarding al sistema de créditos y oportunidades futuras de colaboración.',
      'No hace falta ser nómada digital a tiempo completo: sí hace falta un contenido que encaje de verdad con este mundo.',
    ],
    finalCtaHeading: 'Si tu contenido ya refleja esta forma de vida, puede que *encajes*.',
    finalCtaParagraphs: [
      'Slowork se está construyendo ahora. Quienes se unan pronto no solo lo promocionarán: ayudarán a definir lo que será.',
      'Crea contenido alineado. Gana tu acceso a la experiencia. Ayuda a representar una mejor versión del trabajo remoto.',
    ],
  },
} as const;

const t = ui[lang];

const path = `/${lang}/creators/`;
const baseForUrl = Astro.site ?? Astro.url.origin;
const canonicalURL = new URL(path, baseForUrl).href;
const esCreatorsURL = new URL('/es/creators/', baseForUrl).href;
const enCreatorsURL = new URL('/en/creators/', baseForUrl).href;

const alternates = [
  { hreflang: 'es', href: esCreatorsURL },
  { hreflang: 'en', href: enCreatorsURL },
  { hreflang: 'x-default', href: esCreatorsURL },
] as const;

const ctaHref = `${MAIN_SLOWORK_ORIGIN}/${lang}/#contact`;

const creditOfferDescription =
  lang === 'es'
    ? '1 crédito Slowork equivale a 1 USD de valor en la plataforma. Los créditos no son retirables en efectivo; desbloquean estancias y experiencias dentro de Slowork.'
    : '1 Slowork Credit equals 1 USD in platform value. Credits are not withdrawable cash; they unlock stays and experiences on Slowork.';

const programName =
  lang === 'es' ? 'Programa Slowork Creators' : 'Slowork Creators Program';

const structuredJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: programName,
      description: `${seoDescription} ${creditOfferDescription}`.trim(),
      url: canonicalURL,
      applicationCategory: 'LifestyleApplication',
      operatingSystem: 'Web',
      inLanguage: lang,
      offers: {
        '@type': 'Offer',
        name: lang === 'es' ? 'Créditos para creadores Slowork' : 'Slowork creator credits',
        description: creditOfferDescription,
        price: '1.00',
        priceCurrency: 'USD',
      },
      provider: {
        '@type': 'Organization',
        name: 'Slowork',
        url: MAIN_SLOWORK_ORIGIN,
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    },
  ],
};

const titleSegments = parseEditorialHeading(title);
const storyHeadingSegments = parseEditorialHeading(t.storyHeading);
const howItWorksHeadingSegments = parseEditorialHeading(t.howItWorksHeading);
const finalCtaHeadingSegments = parseEditorialHeading(t.finalCtaHeading);
const whyBuiltClosingSegments = parseEditorialHeading(t.whyBuiltClosing);

const notTypicalIntro = t.notTypicalBody.slice(0, 2);
const notTypicalWrong = t.notTypicalBody[2] ?? '';
const notTypicalRight = t.notTypicalBody[3] ?? '';
---

<BaseLayout title={t.pageTitle} lang={lang} seoDescription={seoDescription} canonicalUrl={canonicalURL}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalURL} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(structuredJsonLd)} />
  </Fragment>

  <div class="relative flex min-h-dvh flex-col text-base-content bg-(--color-bg-landing)">
    <Header lang={lang} />
    
    <main class="flex w-full flex-col">
      {/* 01 / HERO — editorial centered, video below CTA */}
      <section
        class="creators-reveal relative w-full overflow-hidden bg-section-green-light px-6 py-20 text-center md:px-10 md:py-24"
      >
        <div
          class="pointer-events-none absolute -left-28 top-16 h-80 w-80 rounded-full bg-primary/8 blur-3xl"
          aria-hidden="true"
        >
        </div>
        <div
          class="pointer-events-none absolute -right-20 bottom-24 h-96 w-96 rounded-full bg-secondary/10 blur-3xl"
          aria-hidden="true"
        >
        </div>
        <div class="relative mx-auto flex w-full max-w-5xl flex-col items-center pt-16 md:pt-20">
          <div class="mb-6 flex justify-center">
            <span
              class="inline-flex items-center gap-2 rounded-full border border-primary/10 bg-base-100/70 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.18em] text-primary/85 shadow-sm backdrop-blur-sm"
            >
              <Sparkles size={14} stroke-width={2} class="shrink-0 text-secondary" aria-hidden="true" />
              {t.heroBadge}
            </span>
          </div>
          <SectionEyebrow num={1} text="HERO" align="center" />
          <EditorialHeading
            segments={titleSegments}
            as="h1"
            class="mx-auto max-w-4xl text-6xl font-bold leading-[1.05] tracking-[-0.03em] text-primary text-balance md:text-8xl"
          />
          <div class="creators-text-center mx-auto mt-8 max-w-2xl space-y-5 text-lg leading-relaxed text-primary/85 md:text-xl">
            {subheadlineParagraphs.map((p) => (
              <p>{p}</p>
            ))}
          </div>
          <div class="mt-10 flex flex-col items-center gap-4">
            <CreatorsSignatureButton href={ctaHref} ariaLabel={t.ctaAria}>
              {t.cta}
            </CreatorsSignatureButton>
            {heroMicrocopyTrimmed ? (
              <p class="max-w-xl text-sm font-medium text-primary/70 text-pretty">{heroMicrocopyTrimmed}</p>
            ) : null}
          </div>
          <div class="mx-auto mt-14 w-full max-w-4xl">
            <VideoFacade
              hostedVideoSrc={creatorsHeroVideoSrc}
              hostedVideoWebmSrc={creatorsHeroVideoWebmSrc}
              alt={t.videoAlt}
              videoTitle={t.videoTitle}
              playLabel={t.playLabel}
              moodLine={t.videoMoodLine}
              posterPriority
            />
          </div>
        </div>
      </section>

      {/* 02 / STORY */}
      <section class="creators-reveal w-full bg-section-green-dark px-6 py-20 md:px-10 md:py-24">
        <div class="creators-text-center mx-auto flex w-full max-w-3xl flex-col items-center">
          <SectionEyebrow num={2} text="STORY" align="center" />
          <EditorialHeading
            segments={storyHeadingSegments}
            as="h2"
            class="mb-10 text-3xl font-bold tracking-[-0.02em] text-primary text-balance md:text-5xl"
          />
          <div
            class="w-full max-w-2xl rounded-2xl border border-primary/8 bg-[color-mix(in_srgb,var(--color-bg-landing),white_35%)] px-6 py-10 text-left shadow-sm md:px-10 md:py-12"
          >
            <div class="creators-text-start border-l-4 border-secondary pl-6 md:pl-8">
              <div class="space-y-6 text-lg leading-[1.7] text-primary/80 md:text-xl">
                {t.storyBody.map((p) => (
                  <p>{p}</p>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* 03 / WHAT IS SLOWORK — layout retained (text left, mockup right) */}
      <section class="creators-reveal w-full bg-section-green-light px-6 py-20 md:px-10 md:py-24">
        <div class="mx-auto grid max-w-5xl grid-cols-1 items-center gap-10 md:grid-cols-2 md:gap-12">
          <div class="creators-text-start flex min-w-0 w-full flex-col">
            <SectionEyebrow num={3} text="WHAT IS SLOWORK" />
            <h2 class="text-2xl md:text-4xl font-bold text-primary tracking-[-0.02em] mb-8 text-balance">
              {t.whatIsHeading}
            </h2>
            <div class="max-w-prose space-y-6 text-lg text-primary/80 leading-[1.65] md:leading-[1.7]">
              {t.whatIsBody.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </div>
          <figure class="m-0 flex touch-pan-y justify-center md:justify-end perspective-1000">
            <div
              class="mockup-phone border-primary/10 shadow-[0_0_40px_rgba(224,187,68,0.15)] transform rotate-3 transition-transform duration-500 hover:rotate-0 bg-base-100"
              role="img"
              aria-label={
                lang === 'es'
                  ? 'Mockup de la app Slowork — trabajo remoto, estancias naturaleza y espacios para teletrabajar'
                  : 'Slowork app mockup — remote work app, nature stays and workspace discovery for digital nomads'
              }
            >
              <div class="mockup-phone-camera"></div>
              <div class="mockup-phone-display !flex !h-full !min-h-0 !max-h-full !w-full !flex-col !p-0">
                <div class="relative flex min-h-0 flex-1 flex-col overflow-hidden">
                  <ExploreAppMockupScreen lang={lang} />
                </div>
              </div>
            </div>
          </figure>
        </div>
      </section>

      {/* 04 / NOT A TYPICAL PROGRAM — dark editorial */}
      <section class="creators-reveal w-full bg-[#1A1A1A] px-6 py-20 text-center md:px-10 md:py-24">
        <div class="creators-text-center mx-auto flex w-full max-w-4xl flex-col items-center">
          <SectionEyebrow num={4} text="PROGRAM" align="center" tone="on-dark" />
          <h2
            class="mb-10 text-3xl font-bold tracking-[-0.02em] text-white text-balance md:text-5xl"
          >
            {t.notTypicalHeading}
          </h2>
          <div class="mx-auto mb-14 max-w-2xl space-y-6 text-lg leading-relaxed text-white/75 md:text-xl">
            {notTypicalIntro.map((p) => (
              <p>{p}</p>
            ))}
          </div>
          <div class="grid w-full max-w-5xl grid-cols-1 md:grid-cols-2">
            <div class="flex flex-col justify-center border-b border-white/10 bg-white/[0.02] p-10 text-left backdrop-blur-md md:border-b-0 md:border-r">
              <div class="mb-5 flex items-center gap-3 text-red-300/95">
                <CircleX size={28} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                <span class="text-sm font-bold uppercase tracking-widest text-white/90">
                  {t.comparisonWrongLabel}
                </span>
              </div>
              <p class="text-base leading-relaxed text-white/80 text-pretty md:text-lg">{notTypicalWrong}</p>
            </div>
            <div class="flex flex-col justify-center border border-secondary/20 shadow-[0_0_30px_rgba(224,187,68,0.04)] bg-white/[0.02] p-10 text-left backdrop-blur-md relative z-10">
              <div class="mb-5 flex items-center gap-3 text-secondary">
                <CircleCheck size={28} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                <span class="text-sm font-bold uppercase tracking-widest text-white/90">
                  {t.comparisonRightLabel}
                </span>
              </div>
              <p class="text-base leading-relaxed text-white/80 text-pretty md:text-lg">{notTypicalRight}</p>
            </div>
          </div>
        </div>
      </section>

      {/* 05 / WHY BECOME A CREATOR */}
      <section class="creators-reveal w-full bg-section-green-light px-6 py-20 md:px-10 md:py-24">
        <div class="creators-text-center mx-auto flex w-full max-w-6xl flex-col items-center">
          <SectionEyebrow num={5} text="BENEFITS" align="center" />
          <h2
            class:list={[
              'max-w-3xl text-3xl font-bold tracking-[-0.02em] text-primary text-balance md:text-5xl',
              t.whyBecomeIntro.trim() ? 'mb-6' : 'mb-16',
            ]}
          >
            {t.whyBecomeHeading}
          </h2>
          {t.whyBecomeIntro.trim() ? (
            <p class="mx-auto mb-16 max-w-2xl text-lg text-primary/80 text-pretty">{t.whyBecomeIntro}</p>
          ) : null}

          <div class="grid w-full grid-cols-1 gap-10 md:grid-cols-2 md:gap-12 lg:grid-cols-3">
            {benefitBlocks.map((block, index) => (
              <div class="group flex flex-col items-center rounded-3xl border border-primary/10 bg-base-100/40 p-8 text-center shadow-sm transition-shadow duration-300 hover:shadow-lg md:p-10">
                <div
                  class="mb-6 flex h-16 w-16 items-center justify-center rounded-full border border-secondary/35 bg-secondary/12 text-secondary transition-transform duration-300 group-hover:scale-110 group-hover:bg-secondary/20"
                >
                  {index === 0 ? (
                    <Sparkles size={28} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                  ) : index === 1 ? (
                    <CircleDollarSign size={28} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                  ) : index === 2 ? (
                    <Paintbrush size={28} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                  ) : index === 3 ? (
                    <TrendingUp size={28} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                  ) : (
                    <Award size={28} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                  )}
                </div>
                <h3 class="font-editorial-serif text-2xl italic font-normal tracking-[-0.01em] text-primary">{block.title}</h3>
                <p
                  class="mt-4 max-w-sm border-l-4 border-secondary pl-5 text-left text-pretty text-base leading-relaxed text-primary/75"
                >
                  {block.text}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* 06 / WHO THIS IS FOR */}
      <section class="creators-reveal w-full bg-section-green-dark px-6 py-20 md:px-10 md:py-24">
        <div class="creators-text-center mx-auto flex w-full max-w-3xl flex-col items-center">
          <SectionEyebrow num={6} text="AUDIENCE" align="center" />
          <h2 class="mb-10 text-3xl font-bold tracking-[-0.02em] text-primary text-balance md:text-5xl">
            {t.whoForHeading}
          </h2>
          <div class="mb-10 flex flex-wrap justify-center gap-3">
            {t.whoForNiches.map((niche) => (
              <span class="rounded-full border border-primary/10 bg-white/40 px-4 py-1.5 text-sm font-medium text-primary/80 shadow-sm backdrop-blur-sm">
                {niche}
              </span>
            ))}
          </div>
          <div class="mx-auto max-w-prose space-y-6 text-lg leading-relaxed text-primary/80 md:text-xl">
            {t.whoForBody.map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </div>
      </section>

      {/* 07 / WHAT GREAT CONTENT LOOKS LIKE */}
      <section class="creators-reveal w-full bg-section-green-light px-6 py-20 md:px-10 md:py-24">
        <div class="creators-text-center mx-auto flex w-full max-w-5xl flex-col items-center">
          <SectionEyebrow num={7} text="CONTENT" align="center" />
          <h2 class="mb-6 max-w-3xl text-3xl font-bold tracking-[-0.02em] text-primary text-balance md:text-5xl">
            {t.greatContentHeading}
          </h2>
          <p class="mx-auto mb-16 max-w-2xl text-lg text-primary/80 text-pretty md:text-xl">
            {t.greatContentIntro}
          </p>

          <div class="grid w-full grid-cols-1 gap-10 md:grid-cols-2 md:gap-12">
            <div class="rounded-3xl border border-success/20 bg-success/5 p-8 text-left shadow-sm md:p-12">
              <h3 class="mb-6 flex items-center justify-center gap-3 text-xl font-bold text-primary md:justify-start">
                <Check size={24} stroke-width={2} class="shrink-0 text-success" aria-hidden="true" />
                {t.contentWeWant.title}
              </h3>
              <ul class="creators-text-start space-y-4">
                {t.contentWeWant.items.map((item) => (
                  <li class="flex items-start gap-3 text-pretty leading-relaxed text-primary/80">
                    <span class="mt-1 shrink-0 text-success">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-3xl border border-error/20 bg-error/5 p-8 text-left shadow-sm md:p-12">
              <h3 class="mb-6 flex items-center justify-center gap-3 text-xl font-bold text-primary md:justify-start">
                <X size={24} stroke-width={2} class="shrink-0 text-error" aria-hidden="true" />
                {t.contentNotApproved.title}
              </h3>
              <ul class="creators-text-start space-y-4">
                {t.contentNotApproved.items.map((item) => (
                  <li class="flex items-start gap-3 text-pretty leading-relaxed text-primary/80">
                    <span class="mt-1 shrink-0 text-error">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>

      {/* 08 / HOW IT WORKS */}
      <section class="creators-reveal w-full bg-section-green-dark px-6 py-20 md:px-10 md:py-24">
        <div class="creators-text-center mx-auto flex w-full max-w-5xl flex-col items-center">
          <SectionEyebrow num={8} text="PROCESS" align="center" />
          <EditorialHeading
            as="h2"
            segments={howItWorksHeadingSegments}
            class="mb-6 text-3xl font-bold tracking-[-0.02em] text-primary text-balance md:text-5xl"
          />
          <p class="mx-auto mb-16 max-w-2xl text-lg text-primary/80 text-pretty">
            {t.howItWorksIntro}
          </p>

          <div
            class="relative mt-4 flex w-full max-w-5xl flex-col items-center gap-1 md:flex-row md:items-start md:justify-between md:gap-0 md:px-4"
            role="list"
            aria-label={lang === 'es' ? 'Pasos del proceso' : 'Process steps'}
          >
            {t.howItWorksSteps.map((step, idx) => (
              <>
                <div
                  class="group relative z-10 flex w-full max-w-xs flex-col items-center bg-section-green-dark py-6 md:w-auto md:max-w-none md:flex-1 md:px-2 md:py-0 lg:px-3"
                  role="listitem"
                >
                  <div class="flex h-16 w-16 items-center justify-center rounded-2xl border border-primary/10 bg-white/40 text-primary shadow-sm backdrop-blur-sm transition-all duration-300 group-hover:scale-110 group-hover:border-secondary/30 group-hover:bg-secondary/10 group-hover:text-secondary group-hover:shadow-md">
                    {idx === 0 ? (
                      <Camera size={26} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                    ) : idx === 1 ? (
                      <Table2 size={26} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                    ) : idx === 2 ? (
                      <CloudDownload size={26} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                    ) : idx === 3 ? (
                      <ClipboardCheck size={26} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                    ) : (
                      <Sparkles size={26} stroke-width={2} class="shrink-0 text-current" aria-hidden="true" />
                    )}
                  </div>
                  <p class="mt-5 max-w-[120px] text-center text-sm font-medium leading-snug text-primary transition-all duration-300 group-hover:font-bold md:text-[0.9375rem]">
                    {step}
                  </p>
                </div>
                {idx < t.howItWorksSteps.length - 1 ? (
                  <div
                    class="flex shrink-0 items-center justify-center py-2 text-secondary md:h-16 md:py-0 md:pt-0"
                    aria-hidden="true"
                  >
                    <ArrowDown size={26} stroke-width={2.25} class="md:hidden" />
                    <ArrowRight size={26} stroke-width={2.25} class="hidden md:block opacity-90" />
                  </div>
                ) : null}
              </>
            ))}
          </div>
        </div>
      </section>

      {/* 09 / CREDITS SYSTEM */}
      <section class="creators-reveal w-full bg-section-green-light px-6 py-20 md:px-10 md:py-24">
        <div class="creators-text-center mx-auto flex w-full max-w-4xl flex-col items-center">
          <SectionEyebrow num={9} text="CREDITS" align="center" />
          <h2 class="mb-6 text-3xl font-bold tracking-[-0.02em] text-primary text-balance md:text-5xl">
            {t.creditsHeading}
          </h2>
          <div class="mx-auto mb-16 max-w-prose space-y-6 text-lg leading-relaxed text-primary/80 text-pretty">
            {t.creditsIntro.map((p) => (
              <p>{p}</p>
            ))}
          </div>

          <div
            class="mx-auto w-full max-w-2xl rounded-3xl border border-primary/12 bg-white/60 p-6 shadow-[0_12px_40px_-18px_rgba(1,51,51,0.12)] backdrop-blur-sm md:p-12"
          >
            <CreditTable
              rates={creditRates}
              rows={[...t.creditRows]}
              creditsUnitLabel={t.creditsUnitLabel}
              formatColumnLabel={t.creditsTableFormatCol}
              valueColumnLabel={t.creditsTableValueCol}
              caption={t.creditsTableCaption}
              footnote={t.creditsFootnote}
            />
          </div>
        </div>
      </section>

      {/* 10 / WHY WE BUILT THIS */}
      <section class="creators-reveal w-full bg-section-green-dark px-6 py-20 md:px-10 md:py-24">
        <div class="creators-text-center mx-auto flex w-full max-w-4xl flex-col items-center">
          <SectionEyebrow num={10} text="VISION" align="center" />
          <h2 class="mb-10 text-3xl font-bold tracking-[-0.02em] text-primary text-balance md:text-5xl">
            {t.whyBuiltHeading}
          </h2>
          <div class="mx-auto w-full max-w-5xl space-y-12 text-lg leading-relaxed text-primary/80 md:text-xl">
            <div class="space-y-6">
              <p class="mx-auto max-w-2xl text-balance">
                {lang === 'es' ? 'Slowork está en una etapa temprana. Ahora mismo, el objetivo no es escalar. Es ' : 'Slowork is in its early stage. Right now, the goal is not scale. It is '}<span class="font-editorial-serif italic text-primary">clarity</span>{lang === 'es' ? ', ' : ', '}<span class="font-editorial-serif italic text-primary">{lang === 'es' ? 'visibilidad' : 'visibility'}</span>{lang === 'es' ? ' e ' : ' and '}<span class="font-editorial-serif italic text-primary">{lang === 'es' ? 'identidad' : 'identity'}</span>.
              </p>
              <p class="font-semibold text-primary/90">
                {lang === 'es' ? 'Este programa existe para:' : 'This program exists to:'}
              </p>
            </div>
            <ul class="mx-auto flex w-full max-w-4xl flex-wrap justify-center gap-4 lg:gap-6">
              {t.whyBuiltAims.map((item) => (
                <li class="flex w-full items-start gap-4 rounded-2xl border border-primary/5 bg-white/40 px-6 py-6 text-left shadow-[0_8px_30px_-12px_rgba(1,51,51,0.04)] backdrop-blur-sm transition-colors hover:bg-white/60 md:w-[calc(50%-0.5rem)] lg:w-[calc(33.333%-1rem)]">
                  <span class="mt-1.5 h-5 w-0.5 shrink-0 rounded-full bg-secondary/90" aria-hidden="true"></span>
                  <span class="text-pretty text-lg font-medium leading-relaxed text-primary/85">{item}</span>
                </li>
              ))}
            </ul>
            <p class="mt-20 text-center font-editorial-serif text-3xl italic leading-tight text-primary text-balance md:text-5xl">
              {lang === 'es' ? 'Esto es storytelling antes que crecimiento.' : 'This is storytelling before growth.'}
            </p>
          </div>
        </div>
      </section>

      {/* 11 / WHAT HAPPENS NEXT */}
      <section class="creators-reveal w-full bg-section-green-light px-6 py-20 md:px-10 md:py-24">
        <div class="creators-text-center mx-auto flex w-full max-w-5xl flex-col items-center">
          <SectionEyebrow num={11} text="NEXT STEPS" align="center" />
          <h2 class="mb-16 text-3xl font-bold tracking-[-0.02em] text-primary text-balance md:text-5xl">
            {t.whatNextHeading}
          </h2>

          <div class="grid w-full grid-cols-1 gap-8 md:grid-cols-3">
            {t.whatNextBody.map((text, idx) => (
              <div class="rounded-2xl border border-primary/5 bg-white/40 p-8 text-center shadow-[0_8px_30px_-12px_rgba(1,51,51,0.04)] backdrop-blur-sm transition-colors hover:bg-white/60">
                <span class="mb-6 block font-editorial-serif text-4xl italic text-secondary/90">0{idx + 1}</span>
                <p class="text-pretty leading-relaxed text-primary/80">{text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* 12 / FAQ */}
      <section class="creators-reveal w-full bg-section-green-dark px-6 py-20 md:px-10 md:py-24">
        <div class="mx-auto flex w-full max-w-3xl flex-col items-center">
          <SectionEyebrow num={12} text="FAQ" align="center" />
          <CreatorsFaqSection heading={t.faqHeading} items={faqItems} />
        </div>
      </section>

      {/* 13 / FINAL CTA */}
      <section class="creators-reveal w-full bg-section-green-light px-6 py-20 md:px-10 md:py-24">
        <div class="creators-text-center mx-auto flex w-full max-w-4xl flex-col items-center">
          <SectionEyebrow num={13} text="JOIN US" align="center" />
          <EditorialHeading
            as="h2"
            segments={finalCtaHeadingSegments}
            class="mx-auto max-w-4xl text-4xl font-bold leading-[1.08] tracking-[-0.03em] text-primary text-balance md:text-6xl"
          />
          <div class="mx-auto mb-12 mt-10 max-w-prose space-y-6 text-lg leading-relaxed text-primary/80 md:text-xl">
            {t.finalCtaParagraphs.map((p) => (
              <p>{p}</p>
            ))}
          </div>
          <EditorialHeading
            as="p"
            segments={whyBuiltClosingSegments}
            class="mx-auto max-w-4xl text-5xl font-bold leading-[1.05] tracking-[-0.03em] text-primary text-balance md:text-8xl"
          />
          <div class="mt-12">
            <CreatorsSignatureButton href={ctaHref} ariaLabel={t.ctaAria} size="large">
              {t.cta}
            </CreatorsSignatureButton>
          </div>
        </div>
      </section>

    </main>

    <CreatorsLegalFooter lang={lang} />
  </div>
</BaseLayout>
