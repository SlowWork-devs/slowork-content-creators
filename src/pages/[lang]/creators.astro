---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';

import CreditTable from '../../components/CreditTable.astro';
import CreatorsFaqSection from '../../components/CreatorsFaqSection.astro';
import CreatorsLegalFooter from '../../components/CreatorsLegalFooter.astro';
import Header from '../../components/Header.astro';
import SectionEyebrow from '../../components/SectionEyebrow.astro';
import VideoFacade from '../../components/VideoFacade.astro';
import type { CreatorCreditRates } from '../../models/creator-credits.model';
import { MAIN_SLOWORK_ORIGIN, manifestoYoutubeId } from '../../constants/site';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const items = await getCollection('creators');
  return items.map((entry) => ({
    params: { lang: entry.data.locale },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'creators'>;
}

const { entry } = Astro.props;
const lang = Astro.params.lang as 'en' | 'es';

const { title, heroMicrocopy, subheadline, seoDescription, benefitBlocks, faqItems, creditRates } = entry.data;

type CreditRow = { key: keyof CreatorCreditRates; label: string };
const heroMicrocopyTrimmed = heroMicrocopy?.trim() ?? '';

const subheadlineParagraphs = subheadline
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter(Boolean);

const ui = {
  en: {
    cta: 'Apply to join the creators program',
    ctaAria:
      'Apply to join the Slowork creators program — opens the contact section on slowork.app in this window',
    pageTitle: 'Slowork Creators | A different way of living and working',
    videoAlt:
      'Slowork manifesto video — remote work app, nature workspace and intentional lifestyle storytelling',
    playLabel: 'Play the Slowork manifesto video — loads the YouTube player in this frame when activated',
    iframeTitle: 'Slowork Manifesto',
    videoMoodLine: 'Watch now to see how it works',
    faqHeading: 'Frequently asked questions',
    creditsHeading: 'How credits work',
    creditsUnitLabel: 'Credits',
    creditsFootnote: '1 Credit = 1 USD. Not redeemable for cash.',
    creditRows: [
      { key: 'story', label: 'Instagram Story' },
      { key: 'carousel', label: 'Carousel (Instagram or similar)' },
      { key: 'reel', label: 'Reel / short vertical video (Instagram, TikTok)' },
      { key: 'longFormVideo', label: 'Long-form video (e.g. YouTube, typically 40+ min)' },
      { key: 'blogPost', label: 'Blog article' },
    ] satisfies CreditRow[],
    onboardingHeading: 'What happens after you apply',
    onboardingSteps: [
      {
        num: '01',
        title: 'Apply',
        description: 'Send your application—we read every profile with care, not as a volume funnel.',
      },
      {
        num: '02',
        title: 'Review',
        description: 'We assess alignment, storytelling and quality against the Slowork creator brief.',
      },
      {
        num: '03',
        title: 'Onboarding',
        description: 'Selected creators get early access, content guidelines and onboarding into the credit system.',
      },
    ],
    // New UI text for the 13 points
    storyHeading: 'Remote work was supposed to feel freer than this',
    storyBody: [
      'Somewhere along the way, remote work became the same old lifestyle. Same stress. Same burnout. Just with a laptop.',
      'Slowork was built as a response to that.',
      'We believe remote work should feel more human — more connected to place, to people, and to the way you actually want to live.',
    ],
    whatIsHeading: 'What is Slowork?',
    whatIsBody: [
      'Slowork is not just another booking app.',
      "It's a platform for remote workers who want more than good WiFi — places that support deep work, natural environments that improve how you feel, experiences that help you disconnect, and a real sense of community while you travel.",
      'In practical terms: discover remote-ready stays, organise your trip, explore local experiences and connect with others through the app.',
      'A platform, yes. But more importantly — a lifestyle proposition.',
    ],
    notTypicalHeading: 'This is not a typical creator program',
    notTypicalBody: [
      'Most programs are built around campaigns, deliverables and transactional promotion. This one is different.',
      "We're not looking for creators who post the most. We're looking for creators who can represent something meaningful.",
      "If your content is driven by fast ads and generic travel aesthetics — this probably won't fit.",
      "If your content feels thoughtful, visual and intentional — you're exactly who this was designed for.",
    ],
    whyBecomeHeading: 'Why become a Slowork creator',
    whyBecomeIntro:
      "Not every collaboration helps you create work you're proud of. Slowork creators don't just promote a product — they document a lifestyle people already aspire to.",
    whoForHeading: 'Who this program is for',
    whoForBody: [
      'Creators in spaces like: travel · lifestyle · digital nomad · remote work · intentional living · wellbeing',
      'Follower count is not the main filter.',
      'What matters: content that feels relevant, visually strong and genuinely aligned with the Slowork world.',
      "We're especially looking for creators who create in English or subtitle in English, already document meaningful environments, tell stories — not just post aesthetics — and are native to Instagram, TikTok or YouTube.",
    ],
    greatContentHeading: 'What great Slowork content looks like',
    greatContentIntro:
      "We're not looking for content that sells hard. We're looking for content that makes people feel something.",
    contentWeWant: {
      title: 'Content we want',
      items: [
        'Aspirational POVs',
        'Remote work in nature',
        'City vs nature contrasts',
        'Slow routines',
        'Meaningful storytelling',
        'Reflections on work, life and environment',
      ],
    },
    contentNotApproved: {
      title: "Content that won't be approved",
      items: [
        'Direct app promotion',
        'Generic travel montages',
        'Spammy or low-effort content',
        'Giveaway formats',
        'Money-first messaging',
      ],
    },
    howItWorksHeading: 'How it works',
    howItWorksIntro: 'The system is intentionally simple.',
    howItWorksSteps: [
      'Create content',
      'Mention Slowork clearly',
      'Submit it for review',
      'We review it manually',
      'Earn credits',
    ],
    creditsIntro: [
      "Slowork creators don't earn cash per post. They earn credits that unlock the experience.",
      'Each credit = $1 USD in value — redeemable for stays and experiences inside the platform. Credits are not withdrawable.',
      "Credits feel like access, not payment. They bring you closer to the lifestyle you're representing.",
    ],
    whyBuiltHeading: 'Why we built this program',
    whyBuiltIntro:
      "Slowork is early stage. The goal right now isn't scale — it's clarity, visibility and identity.",
    whyBuiltAims: [
      'Build organic awareness',
      'Shape how the brand is perceived',
      'Understand what stories resonate',
      'Attract the right creators early',
      'Lay the foundation for community',
    ],
    whyBuiltClosing: 'This is storytelling before growth.',
    whatNextHeading: 'What happens after you apply',
    whatNextBody: [
      "If your profile feels aligned, we'll review your application.",
      'Selected creators may receive early access, content guidelines, onboarding into the credit system and future collaboration opportunities.',
      "You don't need to be a full-time digital nomad. You just need to create content that genuinely fits this world.",
    ],
    finalCtaHeading: 'If your content already reflects this way of life — you may be a fit.',
    finalCtaParagraphs: [
      "Slowork is being built right now. The creators who join early won't just promote it. They'll help define what it becomes.",
      'Create content that feels aligned. Earn your way into the experience. Help represent a better version of remote work.',
    ],
  },
  es: {
    cta: 'Solicitar unirme al programa de creadores',
    ctaAria:
      'Solicitar unirme al programa de creadores de Slowork — abre la sección de contacto en slowork.app en esta ventana',
    pageTitle: 'Slowork Creators | Una forma distinta de vivir y trabajar',
    videoAlt:
      'Vídeo del manifiesto Slowork — app de trabajo remoto, espacios en naturaleza y estilo de vida intencional',
    playLabel: 'Reproducir el vídeo del manifiesto Slowork — carga el reproductor de YouTube en este espacio al activarlo',
    iframeTitle: 'Manifiesto Slowork',
    videoMoodLine: 'Echa un vistazo para ver cómo funciona',
    faqHeading: 'Preguntas frecuentes',
    creditsHeading: 'Cómo funcionan los créditos',
    creditsUnitLabel: 'Créditos',
    creditsFootnote: '1 crédito = 1 USD. No canjeable en efectivo.',
    creditRows: [
      { key: 'story', label: 'Historia de Instagram' },
      { key: 'carousel', label: 'Carrusel (Instagram o similar)' },
      { key: 'reel', label: 'Reel / vídeo corto vertical (Instagram, TikTok)' },
      { key: 'longFormVideo', label: 'Vídeo largo (p. ej. YouTube, típicamente +40 min)' },
      { key: 'blogPost', label: 'Artículo de blog' },
    ] satisfies CreditRow[],
    onboardingHeading: 'Qué pasa después de aplicar',
    onboardingSteps: [
      {
        num: '01',
        title: 'Solicitar',
        description: 'Envías tu solicitud; leemos cada perfil con calma, sin tratarlo como un embudo masivo.',
      },
      {
        num: '02',
        title: 'Revisión',
        description: 'Valoramos alineación, narrativa y calidad frente al brief de creadores Slowork.',
      },
      {
        num: '03',
        title: 'Onboarding',
        description: 'Si encajas, acceso anticipado, guías de contenido y entrada al sistema de créditos.',
      },
    ],
    // New UI text for the 13 points (Spanish translations)
    storyHeading: 'El trabajo remoto debía sentirse más libre que esto',
    storyBody: [
      'En algún momento, el trabajo remoto se convirtió en el mismo estilo de vida de siempre. Mismo estrés. Mismo agotamiento. Solo que con un portátil.',
      'Slowork nació como respuesta a eso.',
      'Creemos que el trabajo remoto debería sentirse más humano — más ligado al lugar, a las personas y a la forma en que realmente quieres vivir.',
    ],
    whatIsHeading: '¿Qué es Slowork?',
    whatIsBody: [
      'Slowork no es solo otra app de reservas.',
      'Es una plataforma para personas en remoto que quieren algo más que buen WiFi: espacios que favorezcan el trabajo profundo, entornos naturales que mejoren cómo te sientes, experiencias que te ayuden a desconectar y un sentido real de comunidad mientras viajas.',
      'En la práctica: descubre estancias listas para el remoto, organiza tu viaje, explora experiencias locales y conéctate con otras personas desde la app.',
      'Una plataforma, sí. Pero, sobre todo, una propuesta de estilo de vida.',
    ],
    notTypicalHeading: 'Este no es un programa típico para creadores',
    notTypicalBody: [
      'La mayoría de programas giran en torno a campañas, entregables y promoción transaccional. Este es distinto.',
      'No buscamos a quien más publica. Buscamos a quienes pueden representar algo con significado.',
      'Si tu contenido se mueve por anuncios rápidos y estéticas de viaje genéricas, probablemente no encaje.',
      'Si tu contenido se siente reflexivo, visual e intencionado, eres justo a quien va dirigido.',
    ],
    whyBecomeHeading: 'Por qué unirte como creador Slowork',
    whyBecomeIntro:
      'No toda colaboración te ayuda a crear un trabajo del que te sientas orgulloso. Los creadores Slowork no solo promocionan un producto: documentan un estilo de vida al que mucha gente ya aspira.',
    whoForHeading: 'Para quién es este programa',
    whoForBody: [
      'Creadores en ámbitos como: viajes · estilo de vida · nómada digital · trabajo remoto · vida intencionada · bienestar',
      'El número de seguidores no es el filtro principal.',
      'Lo que importa: un contenido relevante, con fuerza visual y alineado de verdad con el universo Slowork.',
      'Nos interesan especialmente perfiles que crean en inglés o subtitulan en inglés, ya documentan entornos con significado, cuentan historias y no solo enseñan estética, y publican de forma nativa en Instagram, TikTok o YouTube.',
    ],
    greatContentHeading: 'Cómo es el contenido Slowork que buscamos',
    greatContentIntro:
      'No buscamos contenido que venda a empujones. Buscamos contenido que haga sentir algo.',
    contentWeWant: {
      title: 'Contenido que queremos',
      items: [
        'Puntos de vista aspiracionales',
        'Trabajo remoto en la naturaleza',
        'Contrastes ciudad vs naturaleza',
        'Rutinas pausadas',
        'Narrativa con sentido',
        'Reflexiones sobre trabajo, vida y entorno',
      ],
    },
    contentNotApproved: {
      title: 'Contenido que no aprobaremos',
      items: [
        'Promoción directa de la app',
        'Montajes de viaje genéricos',
        'Contenido spam o de bajo esfuerzo',
        'Formatos tipo sorteo',
        'Mensajes centrados solo en dinero',
      ],
    },
    howItWorksHeading: 'Cómo funciona',
    howItWorksIntro: 'El sistema es deliberadamente sencillo.',
    howItWorksSteps: [
      'Crea contenido',
      'Menciona Slowork con claridad',
      'Envíalo a revisión',
      'Lo revisamos manualmente',
      'Ganas créditos',
    ],
    creditsIntro: [
      'Los creadores Slowork no cobran en efectivo por publicación. Ganan créditos que desbloquean la experiencia.',
      'Cada crédito equivale a 1 USD en valor, canjeable por estancias y experiencias dentro de la plataforma. Los créditos no son retirables.',
      'Los créditos se sienten como acceso, no como pago. Te acercan al estilo de vida que representas.',
    ],
    whyBuiltHeading: 'Por qué hemos creado este programa',
    whyBuiltIntro:
      'Slowork está en una etapa temprana. Ahora mismo el objetivo no es escalar: es claridad, visibilidad e identidad.',
    whyBuiltAims: [
      'Generar conciencia orgánica',
      'Definir cómo se percibe la marca',
      'Entender qué historias resuenan',
      'Atraer a los creadores adecuados desde el principio',
      'Sentar las bases de la comunidad',
    ],
    whyBuiltClosing: 'Esto es storytelling antes que crecimiento.',
    whatNextHeading: 'Qué pasa después de aplicar',
    whatNextBody: [
      'Si tu perfil encaja, revisamos tu solicitud.',
      'Quienes resulten seleccionados pueden recibir acceso anticipado, guías de contenido, onboarding al sistema de créditos y oportunidades futuras de colaboración.',
      'No hace falta ser nómada digital a tiempo completo: sí hace falta un contenido que encaje de verdad con este mundo.',
    ],
    finalCtaHeading: 'Si tu contenido ya refleja esta forma de vida, puede que encajes.',
    finalCtaParagraphs: [
      'Slowork se está construyendo ahora. Quienes se unan pronto no solo lo promocionarán: ayudarán a definir lo que será.',
      'Crea contenido alineado. Gana tu acceso a la experiencia. Ayuda a representar una mejor versión del trabajo remoto.',
    ],
  },
} as const;

const t = ui[lang];

const path = `/${lang}/creators/`;
const baseForUrl = Astro.site ?? Astro.url.origin;
const canonicalURL = new URL(path, baseForUrl).href;
const esCreatorsURL = new URL('/es/creators/', baseForUrl).href;
const enCreatorsURL = new URL('/en/creators/', baseForUrl).href;

const alternates = [
  { hreflang: 'es', href: esCreatorsURL },
  { hreflang: 'en', href: enCreatorsURL },
  { hreflang: 'x-default', href: esCreatorsURL },
] as const;

const ctaHref = `${MAIN_SLOWORK_ORIGIN}/${lang}/#contact`;

const creditOfferDescription =
  lang === 'es'
    ? '1 crédito Slowork equivale a 1 USD de valor en la plataforma. Los créditos no son retirables en efectivo; desbloquean estancias y experiencias dentro de Slowork.'
    : '1 Slowork Credit equals 1 USD in platform value. Credits are not withdrawable cash; they unlock stays and experiences on Slowork.';

const programName =
  lang === 'es' ? 'Programa Slowork Creators' : 'Slowork Creators Program';

const structuredJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: programName,
      description: `${seoDescription} ${creditOfferDescription}`.trim(),
      url: canonicalURL,
      applicationCategory: 'LifestyleApplication',
      operatingSystem: 'Web',
      inLanguage: lang,
      offers: {
        '@type': 'Offer',
        name: lang === 'es' ? 'Créditos para creadores Slowork' : 'Slowork creator credits',
        description: creditOfferDescription,
        price: '1.00',
        priceCurrency: 'USD',
      },
      provider: {
        '@type': 'Organization',
        name: 'Slowork',
        url: MAIN_SLOWORK_ORIGIN,
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    },
  ],
};

// Helper for alternating backgrounds
const getBgClass = (index: number) => {
  return index % 2 === 0 ? 'bg-(--color-bg-landing)' : 'bg-[color-mix(in_srgb,var(--color-bg-landing),white_15%)]';
};
---

<BaseLayout title={t.pageTitle} lang={lang} seoDescription={seoDescription} canonicalUrl={canonicalURL}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalURL} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(structuredJsonLd)} />
  </Fragment>

  <div class="relative flex min-h-dvh flex-col text-base-content bg-(--color-bg-landing)">
    <Header lang={lang} />
    
    <main class="flex w-full flex-col">
      
      {/* 01 / HERO — horizontal desktop, compact type, left-weighted */}
      <section class={`creators-reveal w-full py-16 md:py-20 lg:py-24 px-6 md:px-10 ${getBgClass(0)}`}>
        <div class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-10 pt-14 md:pt-16 lg:grid-cols-2 lg:gap-12 xl:max-w-7xl xl:gap-14">
          <div class="flex min-w-0 w-full flex-col gap-5 lg:max-w-lg xl:max-w-xl">
            <SectionEyebrow num={1} text="HERO" />
            <h1 class="text-3xl font-bold leading-[1.12] tracking-[-0.02em] text-primary text-balance sm:text-[2rem] md:text-[2.15rem] lg:text-[2.25rem] xl:text-[2.4rem]">
              {title}
            </h1>
            <p class="max-w-prose text-base leading-relaxed text-primary/90 text-pretty md:text-lg">
              {subheadlineParagraphs[0]}
            </p>
            <div class="mt-1 flex w-full max-w-md flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
              <a
                href={ctaHref}
                class="btn btn-secondary creators-cta inline-flex min-h-11 shrink-0 px-8 text-sm font-semibold shadow-md sm:text-base rounded-full"
                aria-label={t.ctaAria}
              >
                {t.cta}
              </a>
              {heroMicrocopyTrimmed && (
                <p class="max-w-prose text-sm font-medium text-primary/70 text-pretty sm:max-w-[18rem]">
                  {heroMicrocopyTrimmed}
                </p>
              )}
            </div>
          </div>

          <div class="w-full min-w-0 rounded-xl shadow-xl lg:rounded-2xl lg:shadow-2xl">
            <VideoFacade
              youtubeId={manifestoYoutubeId}
              alt={t.videoAlt}
              iframeTitle={t.iframeTitle}
              playLabel={t.playLabel}
              moodLine={t.videoMoodLine}
              posterPriority
            />
          </div>
        </div>
      </section>

      {/* 02 / STORY */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(1)}`}>
        <div class="mx-auto flex w-full max-w-3xl flex-col items-stretch">
          <SectionEyebrow num={2} text="STORY" />
          <h2 class="text-2xl md:text-4xl font-bold text-primary tracking-[-0.02em] mb-8 text-balance">
            {t.storyHeading}
          </h2>
          <div class="max-w-prose space-y-6 text-lg text-primary/80 leading-[1.65] md:text-xl md:leading-[1.7]">
            {t.storyBody.map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </div>
      </section>

      {/* 03 / WHAT IS SLOWORK */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(2)}`}>
        <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
          <div class="flex min-w-0 w-full flex-col">
            <SectionEyebrow num={3} text="WHAT IS SLOWORK" />
            <h2 class="text-2xl md:text-4xl font-bold text-primary tracking-[-0.02em] mb-8 text-balance">
              {t.whatIsHeading}
            </h2>
            <div class="max-w-prose space-y-6 text-lg text-primary/80 leading-[1.65] md:leading-[1.7]">
              {t.whatIsBody.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </div>
          <figure class="m-0 flex justify-center md:justify-end perspective-1000">
            <div
              class="mockup-phone border-primary/10 shadow-2xl transform rotate-3 transition-transform duration-500 hover:rotate-0 bg-base-100"
              role="img"
              aria-label={
                lang === 'es'
                  ? 'Mockup de la app Slowork — trabajo remoto, estancias naturaleza y espacios para teletrabajar'
                  : 'Slowork app mockup — remote work app, nature stays and workspace discovery for digital nomads'
              }
            >
              <div class="camera"></div>
              <div class="display">
                <div class="artboard artboard-demo phone-1 bg-base-200 flex flex-col items-center justify-center p-6">
                  <div class="w-full h-48 bg-primary/5 rounded-xl mb-6 animate-pulse"></div>
                  <div class="w-3/4 h-4 bg-primary/10 rounded mb-3"></div>
                  <div class="w-1/2 h-4 bg-primary/10 rounded"></div>
                  <p class="mt-8 text-primary font-medium text-sm">Explore Screen UI</p>
                </div>
              </div>
            </div>
          </figure>
        </div>
      </section>

      {/* 04 / NOT A TYPICAL PROGRAM */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(3)}`}>
        <div class="mx-auto flex w-full max-w-3xl flex-col items-stretch">
          <SectionEyebrow num={4} text="PROGRAM" />
          <h2 class="text-2xl md:text-4xl font-bold text-primary tracking-[-0.02em] mb-8 text-balance">
            {t.notTypicalHeading}
          </h2>
          <div class="max-w-prose space-y-6 text-lg text-primary/80 leading-[1.65] md:leading-[1.7]">
            {t.notTypicalBody.map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </div>
      </section>

      {/* 05 / WHY BECOME A CREATOR */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(4)}`}>
        <div class="mx-auto flex w-full max-w-5xl flex-col items-stretch">
          <SectionEyebrow num={5} text="BENEFITS" />
          <h2
            class={`text-2xl md:text-4xl font-bold text-primary tracking-[-0.02em] text-balance ${t.whyBecomeIntro.trim() ? 'mb-6' : 'mb-16'}`}
          >
            {t.whyBecomeHeading}
          </h2>
          {t.whyBecomeIntro.trim() ? (
            <p class="mx-auto mb-16 w-full max-w-prose text-lg text-primary/80 text-pretty">{t.whyBecomeIntro}</p>
          ) : null}
          
          <div class="grid w-full grid-cols-1 gap-x-12 gap-y-16 md:grid-cols-2 lg:grid-cols-3">
            {benefitBlocks.map((block, index) => (
              <div class="flex flex-col gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary w-8 h-8">
                  <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
                </svg>
                <h3 class="text-lg font-bold text-primary tracking-[-0.01em]">{block.title}</h3>
                <p class="text-pretty text-primary/70 leading-relaxed text-sm md:text-base">{block.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* 06 / WHO THIS IS FOR */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(5)}`}>
        <div class="mx-auto flex w-full max-w-3xl flex-col items-stretch">
          <SectionEyebrow num={6} text="AUDIENCE" />
          <h2 class="text-2xl md:text-4xl font-bold text-primary tracking-[-0.02em] mb-8 text-balance">
            {t.whoForHeading}
          </h2>
          <div class="max-w-prose space-y-6 text-lg text-primary/80 leading-[1.65] md:leading-[1.7]">
            {t.whoForBody.map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </div>
      </section>

      {/* 07 / WHAT GREAT CONTENT LOOKS LIKE */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(6)}`}>
        <div class="mx-auto flex w-full max-w-5xl flex-col items-stretch">
          <SectionEyebrow num={7} text="CONTENT" />
          <h2 class="text-center text-2xl font-bold tracking-[-0.02em] text-primary text-balance md:text-4xl mb-6">
            {t.greatContentHeading}
          </h2>
          <p class="mx-auto mb-16 w-full max-w-prose text-center text-lg text-primary/80 text-pretty md:text-left">
            {t.greatContentIntro}
          </p>
          
          <div class="grid w-full grid-cols-1 gap-12 md:grid-cols-2">
            <div class="bg-primary/5 rounded-3xl p-8 md:p-12">
              <h3 class="text-xl font-bold text-primary mb-6 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success"><path d="M20 6 9 17l-5-5"/></svg>
                {t.contentWeWant.title}
              </h3>
              <ul class="space-y-4">
                {t.contentWeWant.items.map((item) => (
                  <li class="flex items-start gap-3 text-pretty leading-relaxed text-primary/80">
                    <span class="text-success mt-1 shrink-0">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="bg-primary/5 rounded-3xl p-8 md:p-12">
              <h3 class="text-xl font-bold text-primary mb-6 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-error"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                {t.contentNotApproved.title}
              </h3>
              <ul class="space-y-4">
                {t.contentNotApproved.items.map((item) => (
                  <li class="flex items-start gap-3 text-pretty leading-relaxed text-primary/80">
                    <span class="text-error mt-1 shrink-0">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>

      {/* 08 / HOW IT WORKS */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(7)}`}>
        <div class="mx-auto flex w-full max-w-4xl flex-col items-stretch">
          <SectionEyebrow num={8} text="PROCESS" />
          <h2 class="text-2xl md:text-4xl font-bold text-primary tracking-[-0.02em] mb-6 text-balance">
            {t.howItWorksHeading}
          </h2>
          <p class="mx-auto mb-16 w-full max-w-prose text-lg text-primary/80 text-pretty">
            {t.howItWorksIntro}
          </p>
          
          <div class="flex w-full flex-col items-stretch justify-center gap-4 md:flex-row md:gap-8">
            {t.howItWorksSteps.map((step, idx) => (
              <div class="flex flex-col items-stretch gap-4 md:flex-row md:items-stretch md:gap-8">
                <div class="flex w-full min-w-0 flex-col items-stretch md:max-w-[7rem]">
                  <div class="mb-4 flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-primary/20 font-mono text-sm font-bold text-primary">
                    {idx + 1}
                  </div>
                  <h3 class="m-0 text-sm font-medium text-primary">{step}</h3>
                </div>
                {idx < t.howItWorksSteps.length - 1 && (
                  <div class="hidden md:block w-8 h-px bg-primary/20"></div>
                )}
                {idx < t.howItWorksSteps.length - 1 && (
                  <div class="md:hidden h-8 w-px bg-primary/20 my-2"></div>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* 09 / CREDITS SYSTEM */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(8)}`}>
        <div class="mx-auto flex w-full max-w-4xl flex-col items-stretch">
          <SectionEyebrow num={9} text="CREDITS" />
          <h2 class="text-2xl md:text-4xl font-bold text-primary tracking-[-0.02em] mb-6 text-balance">
            {t.creditsHeading}
          </h2>
          <div class="mx-auto mb-16 w-full max-w-prose space-y-6 text-lg font-medium text-primary/80">
            {t.creditsIntro.map((p) => (
              <p>{p}</p>
            ))}
          </div>
          
          <div class="w-full max-w-2xl rounded-3xl bg-primary/5 p-8 md:p-12">
            <CreditTable
              rates={creditRates}
              rows={[...t.creditRows]}
              creditsUnitLabel={t.creditsUnitLabel}
              footnote={t.creditsFootnote}
            />
          </div>
        </div>
      </section>

      {/* 10 / WHY WE BUILT THIS */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(9)}`}>
        <div class="mx-auto flex w-full max-w-3xl flex-col items-stretch">
          <SectionEyebrow num={10} text="VISION" />
          <h2 class="text-2xl md:text-4xl font-bold text-primary tracking-[-0.02em] mb-8 text-balance">
            {t.whyBuiltHeading}
          </h2>
          <div class="max-w-prose space-y-6 text-lg text-primary/80 leading-[1.65] md:leading-[1.7]">
            <p>{t.whyBuiltIntro}</p>
            <p class="font-medium text-primary">
              {lang === 'es' ? 'Este programa existe para:' : 'This program exists to:'}
            </p>
            <ul class="list-disc space-y-3 pl-5 marker:text-primary/50">
              {t.whyBuiltAims.map((item) => (
                <li class="ps-1 leading-relaxed">{item}</li>
              ))}
            </ul>
            <p class="text-xl font-bold text-primary text-pretty">{t.whyBuiltClosing}</p>
          </div>
        </div>
      </section>

      {/* 11 / WHAT HAPPENS NEXT */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(10)}`}>
        <div class="mx-auto flex w-full max-w-4xl flex-col items-stretch">
          <SectionEyebrow num={11} text="NEXT STEPS" />
          <h2 class="text-2xl md:text-4xl font-bold text-primary tracking-[-0.02em] mb-16 text-balance">
            {t.whatNextHeading}
          </h2>
          
          <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
            {t.whatNextBody.map((text, idx) => (
              <div class="bg-primary/5 rounded-2xl p-8">
                <span class="text-secondary font-mono text-sm font-bold block mb-4">0{idx + 1}</span>
                <p class="text-pretty text-primary/80 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* 12 / FAQ */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(11)}`}>
        <div class="mx-auto flex w-full max-w-3xl flex-col items-stretch">
          <SectionEyebrow num={12} text="FAQ" />
          <div class="w-full">
            <CreatorsFaqSection heading={t.faqHeading} items={faqItems} />
          </div>
        </div>
      </section>

      {/* 13 / FINAL CTA */}
      <section class={`creators-reveal w-full py-24 md:py-32 px-6 ${getBgClass(12)}`}>
        <div class="mx-auto flex w-full max-w-3xl flex-col items-stretch">
          <SectionEyebrow num={13} text="JOIN US" />
          <h2 class="text-2xl md:text-4xl font-bold text-primary tracking-[-0.02em] mb-8 text-balance">
            {t.finalCtaHeading}
          </h2>
          <div class="mb-12 max-w-prose space-y-6 text-lg text-primary/80 leading-[1.65] md:leading-[1.7]">
            {t.finalCtaParagraphs.map((p) => (
              <p>{p}</p>
            ))}
          </div>
          <a
            href={ctaHref}
            class="btn btn-secondary creators-cta min-h-12 px-10 text-base font-semibold shadow-md rounded-full"
            aria-label={t.ctaAria}
          >
            {t.cta}
          </a>
        </div>
      </section>

    </main>

    <CreatorsLegalFooter lang={lang} />
  </div>
</BaseLayout>
