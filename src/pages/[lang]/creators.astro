---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';

import CreatorsFaqSection from '../../components/CreatorsFaqSection.astro';
import CreatorsLegalFooter from '../../components/CreatorsLegalFooter.astro';
import Header from '../../components/Header.astro';
import VideoFacade from '../../components/VideoFacade.astro';
import { MAIN_SLOWORK_ORIGIN, manifestoYoutubeId } from '../../constants/site';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const items = await getCollection('creators');
  return items.map((entry) => ({
    params: { lang: entry.data.locale },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'creators'>;
}

const { entry } = Astro.props;
const lang = Astro.params.lang as 'en' | 'es';

const { title, heroMicrocopy, subheadline, seoDescription, benefitBlocks, whyProgram, faqItems } =
  entry.data;
const heroMicrocopyTrimmed = heroMicrocopy?.trim() ?? '';

const subheadlineParagraphs = subheadline
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter(Boolean);

const { Content } = await render(entry);

const ui = {
  en: {
    cta: 'Apply to join the creators program',
    ctaAria:
      'Apply to the Slowork creators program — opens the contact section on slowork.app in this window',
    pageTitle: `${title} | Slowork`,
    videoAlt:
      'Slowork manifesto video — calm, intentional storytelling rooted in nature and community',
    playLabel:
      'Play the Slowork manifesto video — loads the YouTube player in this frame when activated',
    iframeTitle: 'Slowork Manifesto',
    videoMoodLine: 'Feeling: calm, intentional, real.',
    faqHeading: 'Frequently asked questions',
  },
  es: {
    cta: 'Solicitar unirme al programa de creadores',
    ctaAria:
      'Solicitar unirme al programa de creadores de Slowork — abre la sección de contacto en slowork.app en esta ventana',
    pageTitle: `${title} | Slowork`,
    videoAlt:
      'Vídeo del manifiesto Slowork — narrativa calmada e intencionada, naturaleza y comunidad',
    playLabel:
      'Reproducir el vídeo del manifiesto Slowork — carga el reproductor de YouTube en este espacio al activarlo',
    iframeTitle: 'Manifiesto Slowork',
    videoMoodLine: 'Sensación: calma, intención, autenticidad.',
    faqHeading: 'Preguntas frecuentes',
  },
} as const;

const t = ui[lang];

const path = `/${lang}/creators/`;
const baseForUrl = Astro.site ?? Astro.url.origin;
const canonicalURL = new URL(path, baseForUrl).href;
const esCreatorsURL = new URL('/es/creators/', baseForUrl).href;
const enCreatorsURL = new URL('/en/creators/', baseForUrl).href;

const alternates = [
  { hreflang: 'es', href: esCreatorsURL },
  { hreflang: 'en', href: enCreatorsURL },
  { hreflang: 'x-default', href: esCreatorsURL },
] as const;

const ctaHref = `${MAIN_SLOWORK_ORIGIN}/${lang}/#contact`;

const creditOfferDescription =
  lang === 'es'
    ? '1 crédito Slowork equivale a 1 USD de valor en la plataforma. Los créditos no son retirables en efectivo; desbloquean estancias y experiencias dentro de Slowork.'
    : '1 Slowork Credit equals 1 USD in platform value. Credits are not withdrawable cash; they unlock stays and experiences on Slowork.';

/** Un solo JSON-LD reduce parseo en el hilo principal frente a varias etiquetas script. */
const structuredJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: title,
      description: seoDescription,
      url: canonicalURL,
      provider: {
        '@type': 'Organization',
        name: 'Slowork',
        url: MAIN_SLOWORK_ORIGIN,
      },
      areaServed: {
        '@type': 'Place',
        name: 'Worldwide',
      },
      availableLanguage: ['en', 'es'],
      serviceType: 'Content creator program',
      offers: {
        '@type': 'Offer',
        name: lang === 'es' ? 'Créditos para creadores Slowork' : 'Slowork creator credits',
        description: creditOfferDescription,
        price: '1.00',
        priceCurrency: 'USD',
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    },
  ],
};
---

<BaseLayout title={t.pageTitle} lang={lang}>
  <Fragment slot="head">
    <meta name="description" content={seoDescription} />
    <link rel="canonical" href={canonicalURL} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(structuredJsonLd)} />
  </Fragment>

  <div class="relative flex min-h-dvh flex-col bg-base-100 text-base-content">
    <Header lang={lang} />
    <main
      class="mx-auto flex w-full max-w-4xl flex-1 flex-col items-center gap-16 px-6 pb-16 pt-28 md:gap-20 md:pb-24 md:pt-32 lg:pb-28 lg:pt-36"
    >
      <div class="flex w-full flex-col items-center gap-7 text-center md:gap-8">
        <h1 class="max-w-3xl font-bold text-primary text-balance">
          {title}
        </h1>
        <a
          href={ctaHref}
          class="btn btn-secondary creators-cta min-h-12 px-8 text-base font-semibold shadow-md"
          aria-label={t.ctaAria}
        >
          {t.cta}
        </a>
        {heroMicrocopyTrimmed ? (
          <p class="max-w-xl text-sm font-medium leading-relaxed text-base-content/70 text-balance md:text-[0.9375rem]">
            {heroMicrocopyTrimmed}
          </p>
        ) : null}
      </div>

      <section
        class="w-full border-t border-primary/[0.08] pt-14 md:pt-16 lg:pt-20"
        aria-label={lang === 'es' ? 'Introducción' : 'Introduction'}
      >
        <div
          class="creators-story mx-auto max-w-2xl space-y-6 text-lg text-base-content/85 text-balance md:space-y-7 md:text-xl"
        >
          {subheadlineParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </section>

      <section
        class="creators-reveal w-full border-t border-primary/[0.06] pt-14 md:pt-16"
        aria-label={lang === 'es' ? 'En esencia' : 'At a glance'}
      >
        <ul class="mx-auto grid max-w-3xl grid-cols-2 gap-x-5 gap-y-8 md:grid-cols-3 md:gap-x-8 md:gap-y-9">
          {benefitBlocks.map((block, index) => (
            <li class="flex gap-3 text-left">
              <span
                class="mt-0.5 shrink-0 font-mono text-[0.65rem] font-semibold tabular-nums text-primary/35 select-none"
                aria-hidden="true"
              >
                {String(index + 1).padStart(2, '0')}
              </span>
              <div class="min-w-0">
                <p class="text-sm font-bold leading-snug text-primary text-balance md:text-[0.9375rem]">
                  {block.title}
                </p>
                <p class="mt-1.5 text-xs leading-relaxed text-base-content/55 text-balance md:text-[0.8125rem]">
                  {block.text}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </section>

      <section
        class="flex w-full flex-col items-center py-6 md:py-10"
        aria-label={t.iframeTitle}
      >
        <VideoFacade
          youtubeId={manifestoYoutubeId}
          alt={t.videoAlt}
          iframeTitle={t.iframeTitle}
          playLabel={t.playLabel}
          moodLine={t.videoMoodLine}
          posterPriority
        />
      </section>

      <section
        class="w-full border-t border-primary/10 pt-14 md:pt-16"
        aria-labelledby="why-program-heading"
      >
        <h2 id="why-program-heading" class="text-xl font-bold text-primary md:text-2xl">
          {whyProgram.heading}
        </h2>
        <p class="mt-4 max-w-3xl text-base text-base-content/85 leading-relaxed">
          {whyProgram.intro}
        </p>
        <ul class="mt-4 list-inside list-disc space-y-2 text-base text-base-content/85">
          {whyProgram.aims.map((aim) => (
            <li>{aim}</li>
          ))}
        </ul>
        <p class="mt-6 max-w-3xl font-medium text-primary leading-relaxed">
          {whyProgram.closing}
        </p>
      </section>

      <article
        class="w-full max-w-none border-t border-primary/10 pt-14 md:pt-16 [&_h2]:mt-10 [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-primary [&_h2]:first:mt-0 [&_p]:mb-4 [&_p]:leading-relaxed [&_p]:text-base-content/90 [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:text-base-content/90 [&_strong]:font-semibold [&_strong]:text-base-content"
      >
        <Content />
      </article>

      <CreatorsFaqSection heading={t.faqHeading} items={faqItems} />
    </main>

    <CreatorsLegalFooter lang={lang} />
  </div>
</BaseLayout>
